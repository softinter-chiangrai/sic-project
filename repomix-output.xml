<div class="sic-calendar" [attr.data-disabled]="disabled ? 'true' : null">
  @if (label) {
    <span class="sic-calendar__label">
      {{ label }}
    </span>
  }

  <div class="sic-calendar__control">
    <div class="sic-calendar__surface">
      <!-- Toolbar -->
      <div class="sic-calendar__toolbar">
        <div class="sic-calendar__toolbar-left-slot">
          <ng-content select="[sicCalendarToolbarLeft]"></ng-content>
        </div>

        <div class="sic-calendar__toolbar-start">
          <button type="button" class="sic-calendar__today-button" [disabled]="disabled" (click)="goToToday()">
            Today
          </button>

          <div class="sic-calendar__nav-group">
            <button
              type="button"
              class="sic-calendar__nav-button"
              [disabled]="disabled"
              (click)="previousMonth()">
              <i class="bi bi-chevron-left"></i>
            </button>

            <button
              type="button"
              class="sic-calendar__month-year-button"
              [disabled]="disabled"
              (click)="toggleYearView()">
              <span>{{ getMonthYearLabel() }}</span>
              <i class="bi bi-chevron-down"></i>
            </button>

            <button
              type="button"
              class="sic-calendar__nav-button"
              [disabled]="disabled"
              (click)="nextMonth()">
              <i class="bi bi-chevron-right"></i>
            </button>
          </div>
        </div>
      </div>

      <!-- Year/Month Picker (unchanged) -->
      @if (yearViewOpen || monthViewOpen) {
        <button
          type="button"
          class="sic-calendar__picker-backdrop"
          tabindex="-1"
          aria-hidden="true"
          (click)="closePickerOverlay()">
        </button>

        <div class="sic-calendar__picker-modal">
          @if (yearViewOpen) {
            <div class="sic-calendar__picker-panel">
              <div class="sic-calendar__picker-panel-header">
                <span>{{ getYearRangeLabel() }}</span>
              </div>

              <div class="sic-calendar__picker-grid sic-calendar__picker-grid--years">
                @for (year of years; track year) {
                  <button
                    type="button"
                    class="sic-calendar__picker-cell"
                    [attr.data-selected]="currentViewDate.year() === year ? 'true' : null"
                    (click)="selectYear(year)">
                    {{ getDisplayYear(year) }}
                  </button>
                }
              </div>
            </div>
          }

          @if (monthViewOpen) {
            <div class="sic-calendar__picker-panel">
              <div class="sic-calendar__picker-panel-header">
                <span>{{ currentYearLabel }}</span>
              </div>

              <div class="sic-calendar__picker-grid sic-calendar__picker-grid--months">
                @for (month of monthNames; track $index) {
                  <button
                    type="button"
                    class="sic-calendar__picker-cell"
                    [attr.data-selected]="currentViewDate.month() === $index ? 'true' : null"
                    (click)="selectMonth($index)">
                    {{ month }}
                  </button>
                }
              </div>
            </div>
          }
        </div>
      }

      <!-- Weekdays -->
      <div class="sic-calendar__weekdays sic-calendar__weekdays--header">
        @for (day of weekDays; track $index) {
          <div class="sic-calendar__weekday">
            {{ isWideScreen ? weekDaysFull[$index] : day }}
          </div>
        }
      </div>

      <!-- Days Grid -->
      <div class="sic-calendar__days sic-calendar__days--month">
        @for (date of calendarDays; track trackByDate($index, date)) {
          <button
            type="button"
            class="sic-calendar__day"
            [attr.data-other-month]="!isCurrentMonth(date) ? 'true' : null"
            [attr.data-today]="isToday(date) ? 'true' : null"
            [attr.data-selected]="isSelected(date) ? 'true' : null"
            [attr.data-has-tasks]="hasTasks(date) ? 'true' : null"
            [disabled]="disabled || isDateDisabled(date)"
            (click)="selectDate(date)">
            <div class="sic-calendar__day-head">
              <span class="sic-calendar__day-number">{{ date.date() }}</span>
              @if (getOverflowItemCount(date) > 0) {
                <span class="sic-calendar__day-more">+{{ getOverflowItemCount(date) }} more</span>
              }
            </div>

            <div class="sic-calendar__day-events">
              @for (item of getVisibleItemsForDate(date); track trackByItem($index, item)) {
                <span
                  class="sic-calendar__event-pill"
                  [style.--task-color]="item.color || '#4ECDC4'"
                  [attr.data-completed]="item.completed ? 'true' : null"
                  (click)="onItemClick(item, $event)">
                  {{ item.title }}
                </span>
              }
            </div>
          </button>
        }
      </div>
    </div>
  </div>

  @if (hint) {
    <span class="sic-calendar__hint">{{ hint }}</span>
  }
</div>
</file>

<file path="sic-app/src/app/core/component/sic-combobox/sic-combobox.component.html">
<div class="sic-combobox" [attr.data-disabled]="disabled ? 'true' : null" [attr.data-invalid]="showError ? 'true' : null" (focusout)="onFocusOut($event)">
  @if (label) {
    <span class="sic-combobox__label">
      {{ label }}
      @if (isRequired) {
        <span class="sic-combobox__required">*</span>
      }
    </span>
  }

  <div class="sic-combobox__control">
    <div
      #fieldContainer
      class="sic-combobox__field"
      [attr.data-invalid]="showError ? 'true' : null">
      <input
        #fieldInput
        class="sic-combobox__field-input"
        type="text"
        [value]="inputText"
        [placeholder]="placeholder"
        [disabled]="disabled"
        [readonly]="readonly"
        (focus)="onFieldFocus()"
        (blur)="onFieldBlur()"
        (click)="onFieldClick()"
        (input)="onFieldInput(fieldInput.value)"
        (keydown)="handleFieldKeydown($event)" />

      <span class="sic-combobox__field-actions">
        @if (clearable && value !== null && value !== undefined && !readonly && !disabled) {
          <span
            class="sic-combobox__clear"
            role="button"
            tabindex="-1"
            (mousedown)="preventMouseDown($event)"
            (click)="clearSelection($event)">
            <i class="bi bi-x-lg"></i>
          </span>
        }

        <span
          class="sic-combobox__toggle"
          role="button"
          tabindex="-1"
          (mousedown)="preventMouseDown($event)"
          (click)="toggleFromIcon($event)">
          @if (opened) {
            <i class="bi bi-chevron-up"></i>
          } @else {
            <i class="bi bi-chevron-down"></i>
          }
        </span>
      </span>
    </div>

    @if (opened) {
      <button
        type="button"
        class="sic-combobox__backdrop"
        tabindex="-1"
        aria-hidden="true"
        (click)="onBackdropClick()">
      </button>

      <div
        #dropdownPanel
        class="sic-combobox__dropdown"
        [ngStyle]="dropdownPanelStyle">
        <div #optionsPanel class="sic-combobox__options" tabindex="-1" (scroll)="onOptionsScroll($event)">
          @if (showLoadingState) {
            <div class="sic-combobox__state">Loading...</div>
          } @else if (showEmptyState) {
            <div class="sic-combobox__state">{{ emptyText }}</div>
          } @else {
            @for (item of filteredOptions; track trackOption($index, item); let index = $index) {
              <button
                type="button"
                class="sic-combobox__option"
                tabindex="-1"
                [attr.data-selected]="resolveValue(item) === value ? 'true' : null"
                [attr.data-active]="isActiveOption(index) ? 'true' : null"
                (mousedown)="preventMouseDown($event)"
                (mouseup)="selectOption(item)">
                @if (hasProjectedTemplate) {
                  <ng-container
                    *ngTemplateOutlet="optionTemplate?.template ?? null; context: { $implicit: item, item: item }">
                  </ng-container>
                } @else {
                  <span class="sic-combobox__option-label">{{ resolveLabel(item) }}</span>
                }
              </button>
            }
          }
        </div>
      </div>
    }
  </div>

  @if (showError && errorMessage) {
    <span class="sic-combobox__error">{{ errorMessage }}</span>
  } @else if (hint) {
    <span class="sic-combobox__hint">{{ hint }}</span>
  }
</div>
</file>

