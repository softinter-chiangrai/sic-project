            class="cursor-pointer flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text-muted)] transition-colors hover:border-[var(--crm-danger)] hover:text-[var(--crm-danger)]"
            (click)="logout()">
