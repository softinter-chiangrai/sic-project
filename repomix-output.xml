              <td class="px-4 py-3">
                <span class="text-[var(--text)]">{{ getDocumentTypeText(flow.documentType) }}</span>
              </td>
              <td class="px-4 py-3">
                <span class="text-[var(--text-muted)] text-xs">{{ getApprovalModeText(flow.approvalMode) }}</span>
