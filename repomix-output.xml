<!-- src/app/feature/pm/dt/pmdt01/pmdt01A/pmdt01A.component.html -->

<!-- Breadcrumbs -->
<div class="text-sm text-[var(--text-muted)] mb-4 flex items-center gap-1">
  <a [routerLink]="['/feature/pm/pmdt01']" [queryParams]="{ projectId: projectId }" class="hover:text-[var(--crm-primary)]">Phases</a>
  <span>/</span>
  @if (isEdit) {
    <span>Edit Phase</span>
  } @else {
    <span>New Phase</span>
  }
</div>

<div class="max-w-2xl mx-auto">
  <h2 class="text-xl font-semibold text-[var(--text-active)] mb-4">
    {{ isEdit ? 'แก้ไข Phase' : 'สร้าง Phase ใหม่' }}
  </h2>

  <form [formGroup]="form" (ngSubmit)="onSubmit()" class="space-y-4">

    <!-- Phase Name -->
    <div>
      <label class="block text-sm font-medium text-[var(--text)]">ชื่อ Phase <span class="text-red-500">*</span></label>
      <input type="text" formControlName="phaseName" class="w-full px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] focus:ring-2 focus:ring-[var(--crm-primary)]/20 focus:border-[var(--crm-primary)] outline-none transition-all" />
    </div>

    <!-- Description -->
    <div>
      <label class="block text-sm font-medium text-[var(--text)]">คำอธิบาย</label>
      <textarea formControlName="description" rows="3" class="w-full px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] focus:ring-2 focus:ring-[var(--crm-primary)]/20 focus:border-[var(--crm-primary)] outline-none transition-all"></textarea>
    </div>

    <!-- Start Date + Time -->
    <div class="grid grid-cols-2 gap-4">
      <div>
        <sic-datepicker
          label="วันที่เริ่ม"
          formControlName="startDate"
          [required]="true"
          placeholder="เลือกวันที่เริ่ม"
        ></sic-datepicker>
        @if (form.get('startDate')?.touched && form.get('startDate')?.invalid) {
          <p class="text-xs text-[var(--crm-danger)] mt-1">กรุณาระบุวันที่เริ่ม</p>
        }
      </div>
      <div>
        <sic-timepicker
          label="เวลาเริ่ม"
          formControlName="startTime"
          placeholder="เลือกเวลา"
        ></sic-timepicker>
      </div>
    </div>

    <!-- End Date + Time -->
    <div class="grid grid-cols-2 gap-4">
      <div>
        <sic-datepicker
          label="วันที่สิ้นสุด"
          formControlName="endDate"
          [required]="true"
          placeholder="เลือกวันที่สิ้นสุด"
        ></sic-datepicker>
        @if (form.get('endDate')?.touched && form.get('endDate')?.invalid) {
          <p class="text-xs text-[var(--crm-danger)] mt-1">กรุณาระบุวันที่สิ้นสุด</p>
        }
      </div>
      <div>
        <sic-timepicker
          label="เวลาสิ้นสุด"
          formControlName="endTime"
          placeholder="เลือกเวลา"
        ></sic-timepicker>
      </div>
    </div>

    <!-- Owner -->
    <div>
      <label class="block text-sm font-medium text-[var(--text)]">ผู้รับผิดชอบ (Owner)</label>
      <input type="text" formControlName="owner" class="w-full px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] focus:ring-2 focus:ring-[var(--crm-primary)]/20 focus:border-[var(--crm-primary)] outline-none transition-all" />
    </div>

    <!-- Dependency -->
    <div>
      <label class="block text-sm font-medium text-[var(--text)]">Phase ที่ต้องพึ่งพา (Dependency)</label>
      <input type="text" formControlName="dependencyId" placeholder="ระบุ ID (ถ้ามี)" class="w-full px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] focus:ring-2 focus:ring-[var(--crm-primary)]/20 focus:border-[var(--crm-primary)] outline-none transition-all" />
    </div>

    <!-- ✅ Color Picker -->
    <div>
      <sic-colorpicker
        label="เลือกสี Phase"
        formControlName="color"
        placeholder="#4A90D9"
      ></sic-colorpicker>
    </div>

    <!-- Buttons -->
    <div class="flex gap-3 pt-4 border-t border-[var(--border)]">
      <button type="submit" [disabled]="form.invalid" class="px-6 py-2 rounded-lg text-sm font-medium text-white bg-[var(--crm-primary)] hover:bg-[var(--crm-primary)]/80 disabled:opacity-50 transition-all">
        {{ isEdit ? 'บันทึก' : 'สร้าง' }}
      </button>
      <button type="button" (click)="cancel()" class="px-6 py-2 rounded-lg text-sm font-medium border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] transition-all">
        ยกเลิก
      </button>
    </div>

  </form>
</div>
</file>

<file path="sic-app/src/app/feature/pm/dt/pmdt01/pmdt01.component.html">
<!-- src/app/feature/pm/dt/pmdt01/pmdt01.component.html -->
<div class="space-y-5 p-4">

  <!-- Header -->
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold text-[var(--text-active)] flex items-center gap-2">
        <i class="bi bi-layers text-[var(--crm-primary)]"></i>
        Phases & Milestones
      </h1>
      <p class="text-sm text-[var(--text-muted)]">จัดการระยะและเหตุการณ์สำคัญของโครงการ</p>
    </div>
    <button
      (click)="openCreatePhase()"
      class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium text-white bg-[var(--crm-primary)] hover:bg-[var(--crm-primary)]/80 transition-all"
    >
      <i class="bi bi-plus-lg"></i>
      เพิ่ม Phase
    </button>
  </div>

  <!-- Tab Switcher -->
  <div class="flex gap-1 border-b border-[var(--border)]">
    <button
      (click)="viewMode.set('list')"
      class="px-4 py-2 text-sm font-medium transition-colors border-b-2"
      [class]="viewMode() === 'list' ? 'border-[var(--crm-primary)] text-[var(--crm-primary)]' : 'border-transparent text-[var(--text-muted)] hover:text-[var(--text-active)]'"
    >
      <i class="bi bi-grid-3x3-gap-fill mr-1"></i> รายการ
    </button>
    <button
      (click)="viewMode.set('gantt')"
      class="px-4 py-2 text-sm font-medium transition-colors border-b-2"
      [class]="viewMode() === 'gantt' ? 'border-[var(--crm-primary)] text-[var(--crm-primary)]' : 'border-transparent text-[var(--text-muted)] hover:text-[var(--text-active)]'"
    >
      <i class="bi bi-bar-chart-fill mr-1"></i> Gantt
    </button>
  </div>

  <!-- Loading -->
  @if (isLoading()) {
    <div class="flex justify-center py-12">
      <div class="w-10 h-10 border-4 border-[var(--border)] border-t-[var(--crm-primary)] rounded-full animate-spin"></div>
    </div>
  }

  <!-- ===== LIST VIEW ===== -->
  @if (!isLoading() && viewMode() === 'list') {
    @if (phases().length > 0) {
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        @for (phase of phases(); track phase.id) {
          <div
            (click)="goToDetail(phase.id)"
            class="bg-[var(--sidebar)] rounded-xl border border-[var(--border)] p-5 shadow-sm hover:shadow-md hover:border-[var(--crm-primary)]/30 cursor-pointer transition-all"
          >
            <div class="flex justify-between items-start">
              <h3 class="font-semibold text-[var(--text-active)] text-lg">{{ phase.phaseName }}</h3>
              <span [class]="getStatusClass(phase.status) + ' px-2.5 py-0.5 rounded-full text-xs font-medium'">
                {{ getStatusText(phase.status) }}
              </span>
            </div>
            <p class="text-sm text-[var(--text-muted)] mt-1 line-clamp-2">{{ phase.description || 'ไม่มีคำอธิบาย' }}</p>
            <div class="flex items-center gap-4 text-xs text-[var(--text-muted)] mt-3">
              <span><i class="bi bi-calendar3"></i> {{ formatDate(phase.startDate) }} - {{ formatDate(phase.endDate) }}</span>
              <span><i class="bi bi-person"></i> {{ phase.owner || '-' }}</span>
            </div>
            <div class="mt-3 flex items-center gap-4 text-sm">
              <span class="flex items-center gap-1">
                <i class="bi bi-flag text-[var(--crm-primary)]"></i>
                {{ phase.milestoneCount }} Milestones
              </span>
              <span class="flex items-center gap-1">
                <i class="bi bi-list-task text-[var(--crm-primary)]"></i>
                {{ phase.taskCompletedCount }}/{{ phase.taskCount }} Tasks
              </span>
            </div>
            <div class="mt-3 w-full bg-[var(--bg)] rounded-full h-2 overflow-hidden">
              <div class="h-full bg-[var(--crm-primary)] rounded-full transition-all" [style.width.%]="phase.progress"></div>
            </div>
            <div class="flex justify-between text-xs text-[var(--text-muted)] mt-1">
              <span>ความคืบหน้า</span>
              <span>{{ phase.progress }}%</span>
            </div>

            <div class="flex justify-end gap-2 mt-3 border-t border-[var(--border)] pt-3">
              <button
                (click)="editPhase(phase, $event)"
                class="text-sm text-[var(--text-muted)] hover:text-[var(--crm-primary)] transition-colors px-2 py-1 rounded hover:bg-[var(--sidebar-hover)]"
              >
                <i class="bi bi-pencil"></i> แก้ไข
              </button>
              <button
                (click)="deletePhase(phase, $event)"
                class="text-sm text-[var(--text-muted)] hover:text-[var(--crm-danger)] transition-colors px-2 py-1 rounded hover:bg-[var(--sidebar-hover)]"
              >
                <i class="bi bi-trash"></i> ลบ
              </button>
            </div>
          </div>
        }
      </div>
    } @else {
      <div class="text-center py-12 text-[var(--text-muted)]">
        <i class="bi bi-inbox text-5xl block mb-3 opacity-30"></i>
        <p>ยังไม่มี Phase ในโครงการนี้</p>
        <p class="text-sm">คลิก "เพิ่ม Phase" เพื่อเริ่มต้น</p>
      </div>
    }
  }

  <!-- ===== GANTT VIEW ===== -->
  @if (!isLoading() && viewMode() === 'gantt') {
    @if (phases().length > 0) {
      <div class="overflow-x-auto rounded-xl border border-[var(--border)] bg-[var(--sidebar)] shadow-sm">
        <div class="min-w-[600px]">
          <!-- Header: Date labels (simplified) -->
          <div class="flex border-b border-[var(--border)] bg-[var(--bg)]">
            <div class="w-48 flex-shrink-0 px-4 py-2 text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">
              Phase
            </div>
            <div class="flex-1 relative px-4 py-2">
              <div class="flex text-xs text-[var(--text-muted)]">
                @for (i of [].constructor(12); track i) {
                  <span class="flex-1 text-center">{{ i + 1 }}</span>
                }
              </div>
            </div>
          </div>
          <!-- Rows -->
          @for (phase of phases(); track phase.id) {
            <div class="flex border-b border-[var(--border)] hover:bg-[var(--sidebar-hover)] cursor-pointer" (click)="goToDetail(phase.id)">
              <div class="w-48 flex-shrink-0 px-4 py-3 flex items-center">
                <span class="text-sm font-medium text-[var(--text-active)] truncate">{{ phase.phaseName }}</span>
              </div>
              <div class="flex-1 relative px-4 py-3">
                <div class="relative h-8 w-full bg-[var(--bg)] rounded overflow-hidden">
                  <div
                    class="absolute top-1 h-6 rounded transition-all"
                    [style.left.%]="getBarPosition(phase).left"
                    [style.width.%]="getBarPosition(phase).width"
                    [style.background]="phase.status === 'Done' ? 'var(--crm-success)' : phase.status === 'Delayed' ? 'var(--crm-danger)' : 'var(--crm-primary)'"
                    [style.opacity]="0.8"
                  >
                    <span class="absolute inset-0 flex items-center justify-center text-xs text-white font-medium truncate px-1">
                      {{ phase.phaseName }}
                    </span>
                  </div>
                  <!-- Milestone flags (fake) -->
                  @for (ms of phase.milestones; track ms.id) {
                    <div class="absolute top-1 text-sm" [style.left.%]="getBarPosition(phase).left + (getBarPosition(phase).width * 0.5)" title="{{ ms.milestoneName }}">
                      🚩
                    </div>
                  }
                </div>
              </div>
            </div>
          }
        </div>
      </div>
    } @else {
      <div class="text-center py-12 text-[var(--text-muted)]">
        <i class="bi bi-bar-chart text-5xl block mb-3 opacity-30"></i>
        <p>ไม่มีข้อมูลสำหรับแสดงใน Gantt</p>
      </div>
    }
