<div
  class="sic-radio"
  [class.sic-radio--horizontal]="direction === 'horizontal'"
  [class.sic-radio--vertical]="direction === 'vertical'"
  [attr.data-disabled]="disabled ? 'true' : null">
  @if (label) {
    <span class="sic-radio__label">
      {{ label }}
      @if (isRequired) {
        <span class="sic-radio__required">*</span>
      }
    </span>
  }

  <div class="sic-radio__group" [class]="alignmentClass" [attr.role]="'radiogroup'" [attr.aria-invalid]="showError">
    @if (loading) {
      <div class="sic-radio__state">Loading...</div>
    } @else if (showEmptyState) {
      <div class="sic-radio__state">{{ emptyText }}</div>
    } @else {
      @for (option of resolvedOptions; track trackOption($index, option)) {
        <label
          class="sic-radio__option"
          [attr.data-disabled]="isOptionDisabled(option) ? 'true' : null">
          <input
            type="radio"
