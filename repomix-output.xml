        <nav aria-label="Breadcrumb" class="flex flex-wrap items-center gap-2 text-[0.95rem]">
          @for (crumb of breadcrumbs(); track $index) {
          @if ($index > 0) {
          <i class="bi bi-chevron-right text-[0.72rem] text-[var(--text-muted)]"></i>
          }

          @if (crumb.url && !crumb.isCurrent) {
          <a [routerLink]="crumb.url"
            class="inline-flex items-center gap-2 rounded-md px-1 py-0.5 no-underline transition-colors hover:text-[var(--crm-primary)]"
