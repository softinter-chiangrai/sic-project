      <!-- Project Name -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3">
        <sic-input
          label="ชื่อโครงการ"
          formControlName="projectName"
          [required]="true"
          placeholder="ระบบ CRM"
        ></sic-input>
        @if (form.get('projectName')?.touched && form.get('projectName')?.invalid) {
          <p class="text-xs text-[var(--crm-danger)] mt-1">กรุณาระบุชื่อโครงการ</p>
        }
      </div>

      <!-- ✅ Hidden fields -->
      <input type="hidden" formControlName="customerId" />
      <input type="hidden" formControlName="contractId" />
      <input type="hidden" formControlName="contractNo" />

      <!-- Dates -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3 flex gap-6">
        <div class="flex-1">
          <sic-datepicker
