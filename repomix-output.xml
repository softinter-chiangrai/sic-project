            [required]="true"
            placeholder="0"
          ></sic-number>
          @if (form.get('budgetManday')?.touched && form.get('budgetManday')?.invalid) {
            <p class="text-xs text-[var(--crm-danger)] mt-1">กรุณาระบุ Manday</p>
          }
        </div>
        <div class="flex-1">
          <sic-number
            label="Manday ที่ใช้จริง"
