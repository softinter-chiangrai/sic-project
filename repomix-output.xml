          <p class="text-sm text-[var(--text-muted)] mt-2">
            ลูกค้า: <span class="font-medium text-[var(--text-active)]">{{ customerName() }}</span>
          </p>
        }
      </div>

      <!-- Project Code -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3">
        <sic-input
          label="รหัสโครงการ"
          formControlName="projectCode"
          [required]="true"
          placeholder="PRJ-001"
        ></sic-input>
        @if (form.get('projectCode')?.touched && form.get('projectCode')?.invalid) {
          <p class="text-xs text-[var(--crm-danger)] mt-1">กรุณาระบุรหัสโครงการ</p>
