<!-- ═══════════════════════════════════════════════════════════════════════
     sic-headchat — floating bottom-right chat widget
     ════════════════════════════════════════════════════════════════════════ -->
<div class="headchat-root">

  <!-- ── Incoming-call dialog ──────────────────────────────────────────── -->
  @if (incomingCall()) {
    <div class="headchat-incoming">
      <div class="headchat-incoming-icon">
        @if (incomingCall()!.callType === 'video') {
          <i class="bi bi-camera-video-fill"></i>
        } @else {
          <i class="bi bi-telephone-fill"></i>
        }
      </div>
      <div class="headchat-incoming-info">
        <p class="headchat-incoming-name">{{ callerName() }}</p>
        <p class="headchat-incoming-type">
          @if (incomingCall()!.groupName) {
            <i class="bi bi-people-fill"></i> {{ incomingCall()!.groupName }} ·
          }
          {{ incomingCall()!.callType === 'video' ? 'วิดีโอคอล' : 'โทรศัพท์' }}
        </p>
      </div>
      <div class="headchat-incoming-actions">
        <button class="headchat-btn-accept" (click)="acceptCall()" title="รับสาย">
          <i class="bi bi-telephone-fill"></i>
        </button>
        <button class="headchat-btn-reject" (click)="rejectCall()" title="ปฏิเสธ">
          <i class="bi bi-telephone-x-fill"></i>
        </button>
      </div>
    </div>
  }

  <!-- ── Active call overlay ────────────────────────────────────────────── -->
  @if (callStatus() === 'calling' || callStatus() === 'connected') {
    <div class="headchat-call">
      <div class="headchat-call-videos">
        @if (currentGroupCallName()) {
          <div class="headchat-call-group-label">
            <i class="bi bi-people-fill"></i> {{ currentGroupCallName() }}
          </div>
        }
        @if (remoteStream()) {
          <video class="headchat-video-remote" autoplay playsinline
                 [sicStream]="remoteStream()"></video>
        } @else {
          <div class="headchat-call-waiting">
            <i class="bi bi-person-circle"></i>
            <p>{{ callStatus() === 'calling' ? 'กำลังโทร...' : 'กำลังเชื่อมต่อ...' }}</p>
          </div>
        }
        @if (localStream() && currentCallType() === 'video') {
          <video class="headchat-video-local" autoplay playsinline muted
                 [sicStream]="localStream()"></video>
        }
      </div>
      <div class="headchat-call-controls">
        <!-- Screen share (video call only) -->
        @if (currentCallType() === 'video' && callStatus() === 'connected') {
          <button class="headchat-call-btn" [class.active]="isScreenSharing()"
                  (click)="toggleScreenShare()"
                  [title]="isScreenSharing() ? 'หยุดแชร์หน้าจอ' : 'แชร์หน้าจอ'">
            <i class="bi bi-display"></i>
          </button>
        }
        <!-- Mic mute / Camera off (during connected call) -->
        @if (callStatus() === 'connected') {
          <button class="headchat-call-btn" [class.active]="isMicMuted()"
                  (click)="toggleMic()"
                  [title]="isMicMuted() ? 'เปิดไมค์' : 'ปิดไมค์'">
            <i class="bi" [class.bi-mic-mute-fill]="isMicMuted()" [class.bi-mic-fill]="!isMicMuted()"></i>
          </button>
          @if (currentCallType() === 'video') {
            <button class="headchat-call-btn" [class.active]="isCameraOff()"
                    (click)="toggleCamera()"
                    [title]="isCameraOff() ? 'เปิดกล้อง' : 'ปิดกล้อง'">
              <i class="bi" [class.bi-camera-video-off-fill]="isCameraOff()" [class.bi-camera-video-fill]="!isCameraOff()"></i>
            </button>
          }
        }
        <!-- Recording -->
        @if (callStatus() === 'connected') {
          @if (!isRecording()) {
            <button class="headchat-call-btn" (click)="startRecording()" title="บันทึกการสนทนา">
              <i class="bi bi-record-circle"></i>
            </button>
          } @else {
            <span class="headchat-rec-dot" [class.paused]="isRecordingPaused()"></span>
            @if (!isRecordingPaused()) {
              <button class="headchat-call-btn" (click)="pauseRecording()" title="หยุดพักการบันทึก">
                <i class="bi bi-pause-fill"></i>
              </button>
            } @else {
              <button class="headchat-call-btn" (click)="resumeRecording()" title="บันทึกต่อ">
                <i class="bi bi-play-fill"></i>
              </button>
            }
            <button class="headchat-call-btn headchat-call-btn--danger" (click)="stopRecording()" title="หยุดบันทึกและบันทึกลงแชท">
              <i class="bi bi-stop-fill"></i>
            </button>
          }
        }
        <!-- Hang up -->
        <button class="headchat-btn-hangup" (click)="endCall()" title="วางสาย">
          <i class="bi bi-telephone-x-fill"></i>
        </button>
      </div>
      <!-- Peer recording alert -->
      @if (peerIsRecording()) {
        <div class="headchat-rec-alert">
          <i class="bi bi-record-circle-fill"></i>
          อีกฝ่ายกำลังบันทึกการสนทนา
        </div>
      }
    </div>
  }

  <!-- ── Chat windows (max 3) ──────────────────────────────────────────── -->
  @for (chat of openChats(); track chat.peerId; let i = $index) {
    <div class="headchat-window" [style.right.px]="chatWindowRight(i)">

      <!-- Window header -->
      <div class="headchat-win-header">
        <span class="headchat-status-dot" [class.online]="chat.isOnline"></span>
        <div class="headchat-win-avatar">
          @if (chat.peerAvatarUrl) {
            <img [src]="chat.peerAvatarUrl" [alt]="chat.peerName" />
          } @else {
            {{ chat.peerName.charAt(0).toUpperCase() }}
          }
        </div>
        <span class="headchat-win-name" [title]="chat.peerName">{{ chat.peerName }}</span>
        <div class="headchat-win-actions">
          @if (chat.isOnline) {
            <button class="headchat-win-btn" (click)="startCall(chat.peerId, 'audio')" title="โทรด้วยเสียง">
              <i class="bi bi-telephone"></i>
            </button>
            <button class="headchat-win-btn" (click)="startCall(chat.peerId, 'video')" title="วิดีโอคอล">
              <i class="bi bi-camera-video"></i>
            </button>
          }
          <button class="headchat-win-btn headchat-win-close" (click)="closeChat(chat.peerId)" title="ปิด">
            <i class="bi bi-x-lg"></i>
          </button>
        </div>
      </div>

      <!-- Message list -->
      <div class="headchat-messages">
        @if (chat.isLoading) {
          <div class="headchat-loading">
            <span class="headchat-loading-dots"><span></span><span></span><span></span></span>
          </div>
        } @else {
          @for (msg of chat.messages; track msg.id) {
            <div class="headchat-msg"
                 [class.headchat-msg--sent]="msg.senderId === currentUserId()"
                 [class.headchat-msg--received]="msg.senderId !== currentUserId()">
              @if (msg.isCancelled) {
                <span class="headchat-msg-cancelled">ข้อความถูกยกเลิก</span>
              } @else if (msg.messageType === 3) {
                <!-- Call log -->
                <div class="headchat-msg-call">
                  <i class="bi"
                     [class.bi-camera-video-fill]="msg.message === 'video'"
                     [class.bi-telephone-fill]="msg.message !== 'video'"></i>
                  <span>
                    @if (msg.callAccepted == null) {
                      กำลังโทร...
                    } @else if (!msg.callAccepted) {
                      สายไม่ได้รับ
                    } @else {
                      {{ msg.message === 'video' ? 'วิดีโอคอล' : 'โทรศัพท์' }} · {{ formatCallDuration(msg.callDurationSeconds ?? 0) }}
                    }
                  </span>
                </div>
              } @else if (msg.messageType === 2) {
                <!-- File attachment: audio / video / document -->
                @if (msg.attachmentContentType?.startsWith('audio/')) {
                  <div class="headchat-msg-media-wrap">
                    <audio controls [src]="msg.attachmentUrl" class="headchat-msg-audio" preload="metadata"></audio>
                    <div class="headchat-msg-media-footer">
                      <span class="headchat-msg-file-name">{{ msg.attachmentFileName || 'เสียงบันทึก' }}</span>
                      <button class="headchat-msg-dl-btn" (click)="downloadFile(msg.attachmentUrl, msg.attachmentFileName)" title="ดาวน์โหลด">
                        <i class="bi bi-download"></i>
                      </button>
                    </div>
                  </div>
                } @else if (msg.attachmentContentType?.startsWith('video/')) {
                  <div class="headchat-msg-media-wrap">
                    <video controls [src]="msg.attachmentUrl" class="headchat-msg-video" preload="metadata"></video>
                    <div class="headchat-msg-media-footer">
                      <span class="headchat-msg-file-name">{{ msg.attachmentFileName || 'วิดีโอบันทึก' }}</span>
                      <button class="headchat-msg-dl-btn" (click)="downloadFile(msg.attachmentUrl, msg.attachmentFileName)" title="ดาวน์โหลด">
                        <i class="bi bi-download"></i>
                      </button>
                    </div>
                  </div>
                } @else {
                  <div class="headchat-msg-file" (click)="downloadFile(msg.attachmentUrl, msg.attachmentFileName)" role="button" tabindex="0">
                    <i class="bi bi-file-earmark-fill"></i>
                    <div class="headchat-msg-file-info">
                      <span class="headchat-msg-file-name">{{ msg.attachmentFileName || 'ไฟล์แนบ' }}</span>
