        <sic-input-area
          label="หมายเหตุ / Comment"
          formControlName="comment"
          [rows]="2"
          placeholder="เพิ่มรายละเอียดเพิ่มเติมเกี่ยวกับการทดสอบ..."
        ></sic-input-area>
      </div>

      <!-- Buttons -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3 flex gap-6 mt-5">
        <div class="flex-1">
          <sic-button
            [fullWidth]="true"
            [type]="'button'"
            variant="secondary"
            (click)="onBack()"
            [disabled]="isSubmitting"
          >
            <i class="bi bi-arrow-left"></i>
            ย้อนกลับ
          </sic-button>
        </div>
        <div class="flex-1">
          <sic-button
            [fullWidth]="true"
            [type]="'submit'"
            variant="primary"
