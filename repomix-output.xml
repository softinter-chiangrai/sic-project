                [class.rotate-90]="isExpanded(item.code)"></i>
              }
            </span>
            }
          </button>

          } @else {
          <!-- ── Sub level (depth >= 1): ทุก class/attribute เหมือนเดิม 100% ── -->
          <button
            class="relative block w-full rounded-lg bg-transparent px-3 py-2 text-left text-[0.8rem] cursor-pointer hover:bg-[var(--sidebar-hover)]"
            type="button" [routerLink]="item.children?.length ? null : getItemLink(item.path)"
            [class.text-[var(--text-active)]]="isItemActive(item)" [class.font-bold]="isItemActive(item)"
            [class.text-[1rem]]="isItemActive(item)" [class.bg-[var(--sidebar-hover)]]="isItemActive(item)"
            (click)="toggleMenu(item.code, !!item.children?.length)">
            <span class="flex min-w-0 items-center justify-between">
              <span>{{ item.label }}</span>
              @if (item.children?.length) {
              <i class="bi bi-chevron-right text-[0.75rem] transition-transform duration-200 ml-auto"
                [class.rotate-90]="isExpanded(item.code)"></i>
              }
            </span>
          </button>
          }

          <!-- ── Children: กาง/หุบ เหมือนเดิม แต่ recursive ── -->
          @if (item.children?.length) {
          <div class="sidebar-submenu" [class.open]="isExpanded(item.code)"
            [style.padding-left]="depth >= 1 ? '0.95rem' : null">
            <div class="sidebar-submenu-content">
              <ng-container *ngTemplateOutlet="menuNode; context: { items: item.children, depth: depth + 1 }">
              </ng-container>
            </div>
          </div>
          }

          }
        </ng-template>

        <!-- Bootstrap ที่ depth 0 -->
        <ng-container *ngTemplateOutlet="menuNode; context: { items: mainMenu(), depth: 0 }">
        </ng-container>

      </nav>

      <div class="border-t border-[var(--border)] bg-[var(--sidebar)] px-3 py-3">
