            class="w-4 h-4 text-[var(--crm-primary)] focus:ring-[var(--crm-primary)]/20 rounded"
          />
          <span class="text-[var(--text-active)]">เปิดใช้งาน Specification</span>
        </label>
      </div>

      <!-- Buttons -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3 flex gap-6 mt-5">
        <div class="flex-1">
          <sic-button
            [fullWidth]="true"
            [type]="'button'"
            variant="secondary"
            (click)="onBack()"
          >
            <i class="bi bi-arrow-left"></i>
            ย้อนกลับ
          </sic-button>
        </div>
        <div class="flex-1">
          <sic-button
            [fullWidth]="true"
            [type]="'submit'"
            variant="primary"
          >
            <i class="bi bi-floppy"></i>
            {{ isEdit ? 'บันทึก' : 'สร้าง' }}
          </sic-button>
        </div>
      </div>

    </div>
  </form>
}
