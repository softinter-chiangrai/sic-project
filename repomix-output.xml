<div class="space-y-5 p-0.5">
  <!-- HEADER -->
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <h1 class="text-2xl font-semibold text-[var(--text-active)] flex items-center gap-2">
        <i class="bi bi-file-earmark-text text-[var(--crm-primary)]"></i>
        @if (filterCustomerName()) {
          สัญญาของ: {{ filterCustomerName() }}
        } @else {
          รายการสัญญา
        }
      </h1>
      <span
        class="text-sm text-[var(--text-muted)] bg-[var(--bg)] px-3 py-0.5 rounded-full border border-[var(--border)]"
      >
        {{ totalItems() }} รายการ
      </span>
    </div>

    <div class="flex gap-2">
      @if (filterCustomerId()) {
        <button
          (click)="goBackToCustomer()"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] transition-all"
        >
          <i class="bi bi-arrow-left"></i>
          กลับ
        </button>
      }
      <button
        (click)="goToAdd()"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium text-white bg-[var(--crm-primary)] hover:bg-[var(--crm-primary)]/80 transition-all hover:shadow-md"
      >
        <i class="bi bi-plus-lg"></i>
        เพิ่มสัญญา
      </button>
    </div>
  </div>

  <!-- FILTERS -->
  <div class="flex flex-wrap gap-3 items-center">
    <div class="relative flex-1 min-w-[200px]">
      <i
        class="bi bi-search absolute left-3 top-1/2 -translate-y-1/2 text-[var(--text-muted)] text-sm"
      ></i>
      <input
        type="text"
        class="w-full pl-9 pr-9 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--crm-primary)]/20 focus:border-[var(--crm-primary)] transition-all"
        placeholder="ค้นหาเลขสัญญา, ลูกค้า, ประเภท..."
        [value]="searchTerm()"
        (input)="onSearch($event)"
      />
      @if (searchTerm()) {
        <button
          (click)="clearSearch()"
          class="absolute right-3 top-1/2 -translate-y-1/2 text-[var(--text-muted)] hover:text-[var(--text-active)] transition-colors"
        >
          <i class="bi bi-x-lg text-xs"></i>
        </button>
      }
    </div>

    <select
      (change)="onFilterChange($event)"
      [value]="filterStatus()"
      class="px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--crm-primary)]/20 focus:border-[var(--crm-primary)] appearance-none pr-8 cursor-pointer transition-all"
    >
      <option value="all">📊 ทุกสถานะ</option>
      @for (status of statusOptions; track status) {
        <option [value]="status">{{ getStatusText(status) }}</option>
      }
    </select>

    <select
      (change)="onTypeChange($event)"
      [value]="filterType()"
      class="px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--crm-primary)]/20 focus:border-[var(--crm-primary)] appearance-none pr-8 cursor-pointer transition-all"
    >
      <option value="all">📋 ทุกประเภท</option>
      @for (type of contractTypes(); track type) {
        <option [value]="type">{{ type }}</option>
      }
    </select>
  </div>

  <!-- LOADING -->
  @if (isLoading()) {
    <div class="flex flex-col items-center justify-center py-12 gap-3">
      <div
        class="w-10 h-10 border-4 border-[var(--border)] border-t-[var(--crm-primary)] rounded-full animate-spin"
      ></div>
      <p class="text-sm text-[var(--text-muted)]">กำลังโหลดข้อมูล...</p>
    </div>
  }

  <!-- TABLE -->
  @if (!isLoading()) {
    <div
      class="overflow-x-auto rounded-xl border border-[var(--border)] bg-[var(--sidebar)] shadow-sm"
