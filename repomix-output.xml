<div class="space-y-5 p-0.5">

  <!-- ===== HEADER ===== -->
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <h1 class="text-2xl font-semibold text-[var(--text-active)] flex items-center gap-2">
        <i class="bi bi-arrow-left-right text-[var(--crm-primary)]"></i>
        รายการ Change Request
      </h1>
      <span class="text-sm text-[var(--text-muted)] bg-[var(--bg)] px-3 py-0.5 rounded-full border border-[var(--border)]">
        {{ totalItems() }} รายการ
      </span>
    </div>
    <button
      (click)="goToAdd()"
      class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium text-white bg-[var(--crm-primary)] hover:bg-[var(--crm-primary)]/80 transition-all hover:shadow-md"
    >
      <i class="bi bi-plus-lg"></i>
      เพิ่ม Change Request
    </button>
  </div>

  <!-- ===== FILTERS ===== -->
  <div class="flex flex-wrap gap-3 items-center">
    <!-- Search -->
    <div class="relative flex-1 min-w-[200px]">
      <i class="bi bi-search absolute left-3 top-1/2 -translate-y-1/2 text-[var(--text-muted)] text-sm"></i>
      <input
        type="text"
        class="w-full pl-9 pr-9 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--crm-primary)]/20 focus:border-[var(--crm-primary)] transition-all"
        placeholder="ค้นหารหัส, ชื่อ, โครงการ..."
        [value]="searchTerm()"
        (input)="onSearch($event)"
      />
      @if (searchTerm()) {
        <button
          (click)="clearSearch()"
          class="absolute right-3 top-1/2 -translate-y-1/2 text-[var(--text-muted)] hover:text-[var(--text-active)] transition-colors"
        >
          <i class="bi bi-x-lg text-xs"></i>
        </button>
      }
    </div>

    <!-- Filter: Status -->
    <select
      (change)="onFilterChange($event)"
      [value]="filterStatus()"
      class="px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--crm-primary)]/20 focus:border-[var(--crm-primary)] appearance-none pr-8 cursor-pointer transition-all"
    >
      <option value="all">📊 ทุกสถานะ</option>
      @for (status of statusOptions; track status) {
        <option [value]="status">{{ status }}</option>
      }
    </select>

    <!-- Filter: Priority -->
    <select
      (change)="onPriorityChange($event)"
      [value]="filterPriority()"
      class="px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--crm-primary)]/20 focus:border-[var(--crm-primary)] appearance-none pr-8 cursor-pointer transition-all"
    >
      <option value="all">⚡ ทุกระดับ</option>
      @for (priority of priorityOptions; track priority) {
        <option [value]="priority">{{ priority }}</option>
      }
    </select>
  </div>

  <!-- ===== LOADING ===== -->
  @if (isLoading()) {
    <div class="flex flex-col items-center justify-center py-12 gap-3">
      <div class="w-10 h-10 border-4 border-[var(--border)] border-t-[var(--crm-primary)] rounded-full animate-spin"></div>
      <p class="text-sm text-[var(--text-muted)]">กำลังโหลดข้อมูล...</p>
    </div>
  }

  <!-- ===== TABLE ===== -->
  @if (!isLoading()) {
    <div class="overflow-x-auto rounded-xl border border-[var(--border)] bg-[var(--sidebar)] shadow-sm">
      <table class="w-full text-sm">
        <thead class="bg-[var(--bg)] border-b border-[var(--border)]">
          <tr>
            <th class="px-4 py-3 w-10"></th>
            <th
              (click)="onSortChange('requestCode')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[100px]"
            >
              รหัส
              @if (sortBy() === 'requestCode') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th
              (click)="onSortChange('title')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[150px]"
            >
              ชื่อ
              @if (sortBy() === 'title') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th
              (click)="onSortChange('projectName')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[120px]"
            >
              โครงการ
              @if (sortBy() === 'projectName') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th
              (click)="onSortChange('status')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[100px]"
            >
              สถานะ
              @if (sortBy() === 'status') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th
              (click)="onSortChange('priority')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[80px]"
            >
              Priority
              @if (sortBy() === 'priority') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider whitespace-nowrap min-w-[100px]"
            >
              Manday
            </th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider whitespace-nowrap min-w-[160px]">
              จัดการ
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-[var(--border)]">
          @for (cr of paginatedRequests(); track cr.id) {
            <tr class="hover:bg-[var(--sidebar-hover)] transition-colors">
              <td class="px-4 py-3 text-center">
                <button
                  (click)="toggleExpand(cr.id)"
                  class="w-6 h-6 flex items-center justify-center rounded hover:bg-[var(--sidebar-hover)] transition-colors"
                >
                  <i class="bi" [class.bi-chevron-right]="expandedRequest() !== cr.id" [class.bi-chevron-down]="expandedRequest() === cr.id"></i>
                </button>
              </td>
              <td class="px-4 py-3">
                <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold font-mono tracking-wide text-[var(--crm-primary)] bg-[var(--crm-primary)]/10">
                  {{ cr.requestCode }}
                </span>
              </td>
              <td class="px-4 py-3">
                <div>
                  <div class="font-medium text-[var(--text-active)]">{{ cr.title }}</div>
                  <div class="text-xs text-[var(--text-muted)] truncate max-w-[200px]">{{ cr.description }}</div>
                </div>
              </td>
              <td class="px-4 py-3">
                <span class="text-[var(--text)]">{{ cr.projectName }}</span>
              </td>
              <td class="px-4 py-3">
                <span [class]="getStatusClass(cr.status) + ' inline-block px-2.5 py-0.5 rounded-full text-xs font-medium'">
                  {{ cr.status }}
                </span>
              </td>
              <td class="px-4 py-3">
                <span [class]="getPriorityClass(cr.priority) + ' inline-block px-2.5 py-0.5 rounded-full text-xs font-medium'">
                  {{ cr.priority }}
                </span>
              </td>
              <td class="px-4 py-3">
                <span class="text-[var(--text-active)] font-mono">{{ cr.impactManday || 0 }}</span>
              </td>
              <td class="px-4 py-3">
                <div class="flex items-center justify-center gap-1">
                  <!-- View -->
                  <button
                    (click)="goToView(cr.id)"
                    class="w-8 h-8 rounded-lg flex items-center justify-center text-[var(--text-muted)] hover:text-[var(--crm-primary)] hover:bg-[var(--crm-primary)]/10 transition-all"
                    title="ดูข้อมูล"
                  >
                    <i class="bi bi-eye"></i>
                  </button>
                  <!-- Edit -->
                  <button
                    (click)="goToEdit(cr.id)"
                    class="w-8 h-8 rounded-lg flex items-center justify-center text-[var(--text-muted)] hover:text-amber-500 hover:bg-amber-50 dark:hover:bg-amber-500/10 transition-all"
                    title="แก้ไข"
                  >
                    <i class="bi bi-pencil"></i>
                  </button>
                </div>
              </td>
            </tr>
            @if (expandedRequest() === cr.id) {
              <tr class="bg-[var(--bg)]/50">
                <td colspan="8" class="px-4 py-3">
                  <div class="pl-8">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-sm">
                      <div>
                        <p class="text-xs font-semibold text-[var(--text-muted)] uppercase">Impact Analysis</p>
                        <div class="mt-1 space-y-1">
                          @if (cr.impactDfd) {
                            <div><span class="text-xs text-[var(--text-muted)]">DFD:</span> <span class="text-[var(--text-active)]">{{ cr.impactDfd }}</span></div>
                          }
                          @if (cr.impactEr) {
                            <div><span class="text-xs text-[var(--text-muted)]">ER:</span> <span class="text-[var(--text-active)]">{{ cr.impactEr }}</span></div>
                          }
                          @if (cr.impactUi) {
                            <div><span class="text-xs text-[var(--text-muted)]">UI:</span> <span class="text-[var(--text-active)]">{{ cr.impactUi }}</span></div>
                          }
                          @if (cr.impactApi) {
                            <div><span class="text-xs text-[var(--text-muted)]">API:</span> <span class="text-[var(--text-active)]">{{ cr.impactApi }}</span></div>
                          }
                          @if (cr.impactTest) {
                            <div><span class="text-xs text-[var(--text-muted)]">Test:</span> <span class="text-[var(--text-active)]">{{ cr.impactTest }}</span></div>
                          }
                        </div>
                      </div>
                      <div>
                        <p class="text-xs font-semibold text-[var(--text-muted)] uppercase">ผลกระทบด้านเวลาและต้นทุน</p>
                        <div class="mt-1 space-y-1">
                          @if (cr.impactManday) {
                            <div><span class="text-xs text-[var(--text-muted)]">Manday เพิ่ม:</span> <span class="text-[var(--text-active)] font-medium">{{ cr.impactManday }} วัน</span></div>
                          }
                          @if (cr.impactTimeline) {
                            <div><span class="text-xs text-[var(--text-muted)]">Timeline เลื่อน:</span> <span class="text-[var(--text-active)] font-medium">{{ cr.impactTimeline }} วัน</span></div>
                          }
                          @if (cr.impactCost) {
                            <div><span class="text-xs text-[var(--text-muted)]">Cost เพิ่ม:</span> <span class="text-[var(--text-active)] font-medium">{{ formatCurrency(cr.impactCost) }}</span></div>
                          }
                          <div><span class="text-xs text-[var(--text-muted)]">Requirement:</span> <span class="text-[var(--crm-primary)]">{{ cr.requirementCode }}</span></div>
                          <div><span class="text-xs text-[var(--text-muted)]">ผู้ขอ:</span> <span class="text-[var(--text-active)]">{{ cr.requester }}</span></div>
                        </div>
                      </div>
                    </div>
                  </div>
                </td>
              </tr>
            }
          } @empty {
            <tr>
              <td colspan="8" class="px-4 py-12 text-center">
                <div class="flex flex-col items-center gap-3">
                  <i class="bi bi-inbox text-5xl text-[var(--text-muted)] opacity-30"></i>
                  <p class="text-lg font-medium text-[var(--text-active)]">ไม่พบข้อมูล Change Request</p>
                  <p class="text-sm text-[var(--text-muted)]">ปรับคำค้นหาหรือเพิ่ม Change Request ใหม่</p>
                  <button
                    (click)="goToAdd()"
                    class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium text-white bg-[var(--crm-primary)] hover:bg-[var(--crm-primary)]/80 transition-all"
                  >
                    <i class="bi bi-plus-lg"></i>
                    เพิ่ม Change Request
                  </button>
                </div>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }

  <!-- ===== PAGINATION ===== -->
  @if (totalItems() > 0) {
    <div class="flex flex-wrap items-center justify-between gap-3 pt-1">
      <div class="text-sm text-[var(--text-muted)]">
        แสดง
        <strong class="text-[var(--text-active)]">{{ (currentPage() - 1) * pageSize() + 1 }}</strong>
        -
        <strong class="text-[var(--text-active)]">{{ Math.min(currentPage() * pageSize(), totalItems()) }}</strong>
        จาก
        <strong class="text-[var(--text-active)]">{{ totalItems() }}</strong>
        รายการ
      </div>

      <div class="flex gap-1">
        <button
          (click)="onPageChange(currentPage() - 1)"
          [disabled]="!hasPrevious()"
          class="min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] disabled:opacity-30 disabled:cursor-not-allowed transition-all"
        >
          <i class="bi bi-chevron-left"></i>
        </button>

        @for (page of pageNumbers(); track page) {
          <button
            (click)="onPageChange(page)"
            [class]="page === currentPage()
              ? 'min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg bg-[var(--crm-primary)] text-white font-medium transition-all'
              : 'min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] transition-all'
            "
          >
            {{ page }}
          </button>
        }

        <button
          (click)="onPageChange(currentPage() + 1)"
          [disabled]="!hasNext()"
          class="min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] disabled:opacity-30 disabled:cursor-not-allowed transition-all"
        >
          <i class="bi bi-chevron-right"></i>
        </button>
      </div>
    </div>
  }

</div>
</file>

