        <sic-input-area
          label="รายละเอียด"
          formControlName="description"
          [required]="true"
          [rows]="3"
          placeholder="อธิบายความต้องการโดยละเอียด"
        ></sic-input-area>
        @if (form.get('description')?.touched && form.get('description')?.invalid) {
          <p class="text-xs text-[var(--crm-danger)] mt-1">กรุณาระบุรายละเอียด</p>
        }
      </div>

      <!-- Project -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3">
        <sic-combobox
          label="โครงการ"
          formControlName="projectId"
          [apiUrl]="service.apiGetComboboxProject"
          [required]="true"
        ></sic-combobox>
        @if (form.get('projectId')?.touched && form.get('projectId')?.invalid) {
          <p class="text-xs text-[var(--crm-danger)] mt-1">กรุณาเลือกโครงการ</p>
        }
      </div>

      <!-- Requirement Type -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3">
        <sic-combobox
          label="ประเภท Requirement"
          formControlName="requirementType"
          [apiUrl]="service.apiGetLovRequirementType"
          [required]="true"
        ></sic-combobox>
        @if (form.get('requirementType')?.touched && form.get('requirementType')?.invalid) {
          <p class="text-xs text-[var(--crm-danger)] mt-1">กรุณาเลือกประเภท</p>
        }
      </div>

      <!-- Source -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3">
        <label class="block text-sm font-medium text-[var(--text-active)] mb-1">แหล่งที่มา</label>
        <select
          formControlName="source"
          class="w-full px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--crm-primary)]/20 focus:border-[var(--crm-primary)] appearance-none pr-8 transition-all"
        >
          <option value="">-- เลือก --</option>
          @for (src of sourceOptions; track src) {
            <option [value]="src">{{ src }}</option>
          }
        </select>
      </div>

      <!-- Priority -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3">
        <sic-combobox
          label="ลำดับความสำคัญ"
          formControlName="priority"
          [apiUrl]="service.apiGetLovPriority"
          [required]="true"
        ></sic-combobox>
      </div>

      <!-- Business Value -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3">
        <sic-input
          label="คุณค่าทางธุรกิจ"
          formControlName="businessValue"
          placeholder="สูง / ปานกลาง / ต่ำ"
        ></sic-input>
      </div>

      <!-- Acceptance Criteria -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3">
        <sic-input-area
          label="เงื่อนไขการยอมรับ"
          formControlName="acceptanceCriteria"
          [rows]="2"
          placeholder="ระบุเงื่อนไขที่ต้องผ่านเพื่อให้ Requirement นี้สำเร็จ"
        ></sic-input-area>
      </div>

      <!-- Created By -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3">
        <sic-input
          label="ผู้สร้าง"
          formControlName="createdBy"
          placeholder="สมหญิง รักเรียน"
        ></sic-input>
      </div>

      <!-- Version -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3">
        <sic-input
          label="เวอร์ชัน"
          formControlName="version"
          placeholder="v1.0"
        ></sic-input>
      </div>

      <!-- Status -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3">
        <sic-combobox
          label="สถานะ"
          formControlName="status"
          [apiUrl]="service.apiGetLovStatus"
          [required]="true"
        ></sic-combobox>
      </div>

      <!-- Active Status -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3">
        <label class="flex items-center gap-2 cursor-pointer text-sm">
          <input
            type="checkbox"
            formControlName="isActive"
            class="w-4 h-4 text-[var(--crm-primary)] focus:ring-[var(--crm-primary)]/20 rounded"
          />
          <span class="text-[var(--text-active)]">เปิดใช้งาน Requirement</span>
        </label>
      </div>

      <!-- ✅ ส่วนของ Approval -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3 border-t border-[var(--border)] pt-4 mt-2">
        <div class="text-sm font-medium text-[var(--text-active)] mb-2 flex items-center gap-2">
          <i class="bi bi-check2-circle text-[var(--crm-primary)]"></i>
          การอนุมัติ
        </div>
        
        <!-- เลือก Approval Flow -->
        <div class="mb-3">
          <sic-combobox
            label="กระบวนการอนุมัติ"
            [apiUrl]="'/api/pm/approvals/flows/document-type/REQUIREMENT'"
            valueField="id"
            textField="flowName"
            placeholder="เลือกกระบวนการอนุมัติ"
            [clearable]="true"
            (selectionChanged)="selectedFlowId = $event?.id"
          ></sic-combobox>
        </div>

        <!-- ปุ่มส่งขออนุมัติ -->
        <sic-button
          variant="primary"
          [fullWidth]="false"
          [disabled]="!selectedFlowId || !form.get('id')?.value"
          (click)="submitForApproval()"
        >
          <i class="bi bi-send"></i>
          ส่งขออนุมัติ
        </sic-button>
        @if (!form.get('id')?.value) {
          <p class="text-xs text-[var(--text-muted)] mt-1">* กรุณาบันทึก Requirement ก่อนส่งขออนุมัติ</p>
        }
      </div>

      <!-- Buttons -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3 flex gap-6 mt-5">
        <div class="flex-1">
          <sic-button
            [fullWidth]="true"
            [type]="'button'"
            variant="secondary"
            (click)="onBack()"
          >
            <i class="bi bi-arrow-left"></i>
            ย้อนกลับ
          </sic-button>
        </div>
        <div class="flex-1">
          <sic-button
            [fullWidth]="true"
            [type]="'submit'"
            variant="primary"
          >
            <i class="bi bi-floppy"></i>
            {{ isEdit ? 'บันทึก' : 'สร้าง' }}
          </sic-button>
        </div>
      </div>

    </div>
  </form>
}
</file>

