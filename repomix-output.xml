          @for (project of projects(); track project.id) {
            <tr class="hover:bg-[var(--sidebar-hover)] transition-colors">
              <td class="px-4 py-3">
                <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold font-mono tracking-wide text-[var(--crm-primary)] bg-[var(--crm-primary)]/10">
                  {{ project.projectCode }}
                </span>
              </td>
              <td class="px-4 py-3">
                <span class="font-medium text-[var(--text-active)]">{{ project.projectName }}</span>
              </td>
              <td class="px-4 py-3">
                <span class="text-[var(--text)]">{{ project.customerName }}</span>
              </td>
              <td class="px-4 py-3">
                <span [class]="getStatusClass(project.status) + ' inline-block px-2.5 py-0.5 rounded-full text-xs font-medium'">
                  {{ getStatusText(project.status) }}
                </span>
              </td>
              <td class="px-4 py-3">
                <div class="flex flex-col gap-0.5">
                  <div class="flex justify-between text-xs">
                    <span class="text-[var(--text-muted)]">{{ project.usedManday }}/{{ project.budgetManday }}</span>
                    <span class="font-medium text-[var(--text-active)]">{{ getProgress(project.usedManday, project.budgetManday) }}%</span>
                  </div>
                  <div class="w-full h-1.5 bg-[var(--bg)] rounded-full overflow-hidden">
                    <div
                      class="h-full rounded-full transition-all"
                      [style.width.%]="getProgress(project.usedManday, project.budgetManday)"
                      [style.background]="getProgress(project.usedManday, project.budgetManday) > 80 ? 'var(--crm-danger)' : getProgress(project.usedManday, project.budgetManday) > 50 ? 'var(--crm-warning)' : 'var(--crm-success)'"
                    ></div>
                  </div>
                </div>
              </td>
              <td class="px-4 py-3 text-sm text-[var(--text-muted)] font-mono hidden md:table-cell">
                {{ formatDate(project.startDate) }} - {{ formatDate(project.plannedEndDate) }}
              </td>
              <td class="px-4 py-3">
                <span [class]="getPriorityClass(project.priority) + ' inline-block px-2.5 py-0.5 rounded-full text-xs font-medium'">
                  {{ project.priority }}
                </span>
              </td>
              <td class="px-4 py-3">
                <div class="flex items-center justify-center gap-1">
                  <button
                    (click)="goToView(project.id)"
                    class="w-8 h-8 rounded-lg flex items-center justify-center text-[var(--text-muted)] hover:text-[var(--crm-primary)] hover:bg-[var(--crm-primary)]/10 transition-all"
                    title="ดู Dashboard"
                  >
                    <i class="bi bi-speedometer2"></i>
                  </button>
                  <button
                    (click)="goToEdit(project.id)"
                    class="w-8 h-8 rounded-lg flex items-center justify-center text-[var(--text-muted)] hover:text-amber-500 hover:bg-amber-50 dark:hover:bg-amber-500/10 transition-all"
                    title="แก้ไข"
                  >
                    <i class="bi bi-pencil"></i>
                  </button>
                </div>
              </td>
            </tr>
          } @empty {
            <tr>
              <td colspan="8" class="px-4 py-12 text-center">
                <div class="flex flex-col items-center gap-3">
                  <i class="bi bi-inbox text-5xl text-[var(--text-muted)] opacity-30"></i>
                  <p class="text-lg font-medium text-[var(--text-active)]">ไม่พบข้อมูลโครงการ</p>
                  <p class="text-sm text-[var(--text-muted)]">ปรับคำค้นหาหรือเพิ่มโครงการใหม่</p>
                  <button (click)="goToAdd()" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium text-white bg-[var(--crm-primary)] hover:bg-[var(--crm-primary)]/80 transition-all">
                    <i class="bi bi-plus-lg"></i> เพิ่มโครงการ
                  </button>
                </div>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }

  <!-- PAGINATION -->
  @if (totalItems() > 0) {
    <div class="flex flex-wrap items-center justify-between gap-3 pt-1">
      <div class="text-sm text-[var(--text-muted)]">
        แสดง
        <strong class="text-[var(--text-active)]">{{ (currentPage() - 1) * pageSize() + 1 }}</strong>
        -
        <strong class="text-[var(--text-active)]">{{ Math.min(currentPage() * pageSize(), totalItems()) }}</strong>
        จาก
        <strong class="text-[var(--text-active)]">{{ totalItems() }}</strong>
        รายการ
      </div>

      <div class="flex gap-1">
        <button
          (click)="onPageChange(currentPage() - 1)"
          [disabled]="!hasPrevious()"
          class="min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] disabled:opacity-30 disabled:cursor-not-allowed transition-all"
        >
          <i class="bi bi-chevron-left"></i>
        </button>

        @for (page of pageNumbers(); track page) {
          <button
            (click)="onPageChange(page)"
            [class]="page === currentPage()
              ? 'min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg bg-[var(--crm-primary)] text-white font-medium transition-all'
              : 'min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] transition-all'
            "
          >
            {{ page }}
          </button>
        }

        <button
          (click)="onPageChange(currentPage() + 1)"
          [disabled]="!hasNext()"
          class="min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] disabled:opacity-30 disabled:cursor-not-allowed transition-all"
        >
          <i class="bi bi-chevron-right"></i>
        </button>
      </div>
    </div>
  }

</div>
</file>

<file path="sic-app/src/app/feature/pm/rt/pmrt03/pmrt03.component.html">
<!-- src/app/feature/pm/rt/pmrt03/pmrt03.component.html -->

<!-- ===== LOADING ===== -->
@if (isLoading()) {
  <div class="flex flex-col items-center justify-center py-20 gap-4">
    <div
      class="w-14 h-14 border-4 border-[var(--border)] border-t-[var(--crm-primary)] rounded-full animate-spin"
    ></div>
    <p class="text-[var(--text-muted)]">กำลังโหลดข้อมูลโครงการ...</p>
  </div>
}

<!-- ===== ERROR ===== -->
@if (error()) {
  <div class="flex flex-col items-center justify-center py-20 gap-4">
    <i class="bi bi-exclamation-triangle text-5xl text-[var(--crm-danger)]"></i>
    <p class="text-lg font-medium text-[var(--text-active)]">{{ error() }}</p>
    <button
      (click)="goBack()"
      class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] transition-all"
    >
      <i class="bi bi-arrow-left"></i>
      กลับไปหน้ารายการ
    </button>
  </div>
}

<!-- ===== DASHBOARD ===== -->
@if (project(); as p) {
  <div class="space-y-6 p-0.5">
    <!-- ===== HEADER ===== -->
    <div class="flex flex-wrap items-center justify-between gap-4">
      <div class="flex items-center gap-4">
        <button
          (click)="goBack()"
          class="w-9 h-9 rounded-lg flex items-center justify-center text-[var(--text-muted)] hover:text-[var(--crm-primary)] hover:bg-[var(--crm-primary)]/10 transition-all"
          title="กลับ"
        >
          <i class="bi bi-arrow-left text-xl"></i>
        </button>
        <div>
          <div class="flex items-center gap-3 flex-wrap">
            <h1 class="text-2xl font-bold text-[var(--text-active)]">{{ p.projectName }}</h1>
            <span
              class="inline-block px-2 py-0.5 rounded text-xs font-semibold font-mono bg-[var(--crm-primary)]/10 text-[var(--crm-primary)]"
            >
              {{ p.projectCode }}
            </span>
            <span
              [class]="
                getStatusClass(p.status) +
                ' inline-block px-2.5 py-0.5 rounded-full text-xs font-medium'
              "
            >
              {{ getStatusText(p.status) }}
            </span>
            @if (!p.isActive) {
              <span
                class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400"
              >
                ปิดใช้งาน
              </span>
            }
          </div>
          <div class="flex items-center gap-4 text-sm text-[var(--text-muted)] mt-1 flex-wrap">
            <span><i class="bi bi-person"></i> {{ p.customerName }}</span>
            <span><i class="bi bi-file-earmark-text"></i> สัญญา: {{ p.contractNo }}</span>
            <span><i class="bi bi-person-badge"></i> PM: {{ p.projectManager }}</span>
            <span
              ><i class="bi bi-calendar"></i> {{ formatDate(p.startDate) }} -
              {{ formatDate(p.plannedEndDate) }}</span
            >
          </div>
        </div>
      </div>

      <div class="flex gap-2">
        <button
          (click)="goToGantt()"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] transition-all"
        >
          <i class="bi bi-bar-chart"></i>
          Gantt
        </button>
        <button
          (click)="goToEdit()"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium text-white bg-[var(--crm-primary)] hover:bg-[var(--crm-primary)]/80 transition-all hover:shadow-md"
        >
          <i class="bi bi-pencil"></i>
          แก้ไขโครงการ
        </button>
      </div>
    </div>

    <!-- ===== STATS CARDS ===== -->
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
      <div class="bg-[var(--sidebar)] rounded-xl border border-[var(--border)] p-4 shadow-sm">
        <p class="text-xs text-[var(--text-muted)] uppercase tracking-wider">Phase</p>
        <p class="text-2xl font-bold text-[var(--text-active)]">{{ p.phaseCount }}</p>
      </div>
      <div class="bg-[var(--sidebar)] rounded-xl border border-[var(--border)] p-4 shadow-sm">
        <p class="text-xs text-[var(--text-muted)] uppercase tracking-wider">Tasks</p>
        <p class="text-2xl font-bold text-[var(--text-active)]">{{ p.taskCount }}</p>
        <p class="text-xs text-[var(--text-muted)]">
          เสร็จ {{ p.taskCompletedCount }} / {{ p.taskCount }}
        </p>
      </div>
      <div class="bg-[var(--sidebar)] rounded-xl border border-[var(--border)] p-4 shadow-sm">
        <p class="text-xs text-[var(--text-muted)] uppercase tracking-wider">Requirements</p>
        <p class="text-2xl font-bold text-[var(--text-active)]">{{ p.requirementCount }}</p>
      </div>
      <div class="bg-[var(--sidebar)] rounded-xl border border-[var(--border)] p-4 shadow-sm">
        <p class="text-xs text-[var(--text-muted)] uppercase tracking-wider">Bugs</p>
        <p class="text-2xl font-bold text-[var(--text-active)]">{{ p.bugCount }}</p>
        <p class="text-xs text-[var(--text-muted)]">เปิด {{ p.bugOpenCount }} / {{ p.bugCount }}</p>
      </div>
      <div
        class="bg-[var(--sidebar)] rounded-xl border border-[var(--border)] p-4 shadow-sm col-span-2"
      >
        <p class="text-xs text-[var(--text-muted)] uppercase tracking-wider">Manday</p>
        <div class="flex items-center gap-3">
          <span class="text-2xl font-bold text-[var(--text-active)]">{{ p.usedManday }}</span>
          <span class="text-sm text-[var(--text-muted)]">/ {{ p.budgetManday }}</span>
          <span class="text-sm font-medium text-[var(--text-active)] ml-auto"
            >{{ getMandayProgress() }}%</span
          >
        </div>
        <div class="w-full h-2 bg-[var(--bg)] rounded-full overflow-hidden mt-1">
          <div
            class="h-full rounded-full transition-all"
            [style.width.%]="getMandayProgress()"
            [style.background]="
              getMandayProgress() > 80
                ? 'var(--crm-danger)'
                : getMandayProgress() > 50
                  ? 'var(--crm-warning)'
                  : 'var(--crm-success)'
            "
          ></div>
        </div>
      </div>
    </div>

    <!-- ===== DESCRIPTION ===== -->
    @if (p.description) {
      <div class="bg-[var(--sidebar)] rounded-xl border border-[var(--border)] p-4 shadow-sm">
        <p class="text-sm text-[var(--text)]">{{ p.description }}</p>
      </div>
    }

    <!-- ===== QUICK ACTIONS ===== -->
    <div>
      <h2 class="text-lg font-semibold text-[var(--text-active)] mb-3 flex items-center gap-2">
        <i class="bi bi-grid-3x3-gap-fill text-[var(--crm-primary)]"></i>
        เมนูด่วน
      </h2>
      <div
        class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 xl:grid-cols-7 gap-2"
      >
        <!-- Phase -->
        <button
          (click)="goToPhases()"
          class="flex flex-col items-center justify-center gap-1 px-3 py-3 rounded-lg border border-[var(--border)] bg-[var(--sidebar)] hover:bg-[var(--sidebar-hover)] transition-all text-sm text-[var(--text)]"
        >
          <i class="bi bi-layers text-xl text-[var(--crm-primary)]"></i>
          <span>Phase</span>
        </button>
        <!-- Requirement -->
        <button
          (click)="goToRequirements()"
          class="flex flex-col items-center justify-center gap-1 px-3 py-3 rounded-lg border border-[var(--border)] bg-[var(--sidebar)] hover:bg-[var(--sidebar-hover)] transition-all text-sm text-[var(--text)]"
        >
          <i class="bi bi-clipboard-check text-xl text-[var(--crm-primary)]"></i>
          <span>Requirement</span>
        </button>
        <!-- Change Request -->
        <button
          (click)="goToChangeRequests()"
          class="flex flex-col items-center justify-center gap-1 px-3 py-3 rounded-lg border border-[var(--border)] bg-[var(--sidebar)] hover:bg-[var(--sidebar-hover)] transition-all text-sm text-[var(--text)]"
        >
          <i class="bi bi-arrow-left-right text-xl text-[var(--crm-warning)]"></i>
          <span>Change Request</span>
        </button>
        <!-- Specification -->
        <button
          (click)="goToSpecifications()"
          class="flex flex-col items-center justify-center gap-1 px-3 py-3 rounded-lg border border-[var(--border)] bg-[var(--sidebar)] hover:bg-[var(--sidebar-hover)] transition-all text-sm text-[var(--text)]"
        >
          <i class="bi bi-file-text text-xl text-[var(--crm-primary)]"></i>
          <span>Specification</span>
        </button>
        <button
          (click)="goToDiagram()"
          class="flex flex-col items-center justify-center gap-1 px-3 py-3 rounded-lg border border-[var(--border)] bg-[var(--sidebar)] hover:bg-[var(--sidebar-hover)] transition-all text-sm text-[var(--text)]"
        >
          <i class="bi bi-diagram-2 text-xl text-[var(--crm-primary)]"></i>
          <span>Diagram</span>
        </button>
        <!-- Design Review -->
        <button
          (click)="goToDesignReviews()"
          class="flex flex-col items-center justify-center gap-1 px-3 py-3 rounded-lg border border-[var(--border)] bg-[var(--sidebar)] hover:bg-[var(--sidebar-hover)] transition-all text-sm text-[var(--text)]"
        >
          <i class="bi bi-eye text-xl text-[var(--crm-primary)]"></i>
          <span>Design Review</span>
        </button>
        <!-- Planning / Manday -->
        <button
          (click)="goToPlanning()"
          class="flex flex-col items-center justify-center gap-1 px-3 py-3 rounded-lg border border-[var(--border)] bg-[var(--sidebar)] hover:bg-[var(--sidebar-hover)] transition-all text-sm text-[var(--text)]"
        >
          <i class="bi bi-calendar-check text-xl text-[var(--crm-primary)]"></i>
          <span>Planning</span>
        </button>
        <!-- Tasks -->
        <button
          (click)="goToTasks()"
          class="flex flex-col items-center justify-center gap-1 px-3 py-3 rounded-lg border border-[var(--border)] bg-[var(--sidebar)] hover:bg-[var(--sidebar-hover)] transition-all text-sm text-[var(--text)]"
        >
          <i class="bi bi-list-task text-xl text-[var(--crm-primary)]"></i>
          <span>Tasks</span>
        </button>
        <!-- Discussion -->
        <button
          (click)="goToDiscussion()"
          class="flex flex-col items-center justify-center gap-1 px-3 py-3 rounded-lg border border-[var(--border)] bg-[var(--sidebar)] hover:bg-[var(--sidebar-hover)] transition-all text-sm text-[var(--text)]"
        >
          <i class="bi bi-chat-dots text-xl text-[var(--crm-primary)]"></i>
          <span>Discussion</span>
        </button>
        <!-- Test Case -->
        <button
          (click)="goToTestCases()"
          class="flex flex-col items-center justify-center gap-1 px-3 py-3 rounded-lg border border-[var(--border)] bg-[var(--sidebar)] hover:bg-[var(--sidebar-hover)] transition-all text-sm text-[var(--text)]"
        >
          <i class="bi bi-check2-square text-xl text-[var(--crm-primary)]"></i>
          <span>Test Case</span>
        </button>
        <!-- Bug -->
        <button
          (click)="goToBugs()"
          class="flex flex-col items-center justify-center gap-1 px-3 py-3 rounded-lg border border-[var(--border)] bg-[var(--sidebar)] hover:bg-[var(--sidebar-hover)] transition-all text-sm text-[var(--text)]"
        >
          <i class="bi bi-bug text-xl text-[var(--crm-danger)]"></i>
          <span>Bug</span>
        </button>
        <!-- Delivery -->
        <button
          (click)="goToDeliveries()"
          class="flex flex-col items-center justify-center gap-1 px-3 py-3 rounded-lg border border-[var(--border)] bg-[var(--sidebar)] hover:bg-[var(--sidebar-hover)] transition-all text-sm text-[var(--text)]"
        >
          <i class="bi bi-box-seam text-xl text-[var(--crm-primary)]"></i>
          <span>Delivery</span>
        </button>
        <!-- Manual -->
        <button
          (click)="goToManuals()"
          class="flex flex-col items-center justify-center gap-1 px-3 py-3 rounded-lg border border-[var(--border)] bg-[var(--sidebar)] hover:bg-[var(--sidebar-hover)] transition-all text-sm text-[var(--text)]"
        >
          <i class="bi bi-book text-xl text-[var(--crm-primary)]"></i>
          <span>Manual</span>
        </button>
        <!-- Contract -->
        <button
          (click)="goToContracts()"
          class="flex flex-col items-center justify-center gap-1 px-3 py-3 rounded-lg border border-[var(--border)] bg-[var(--sidebar)] hover:bg-[var(--sidebar-hover)] transition-all text-sm text-[var(--text)]"
        >
          <i class="bi bi-file-earmark-text text-xl text-[var(--crm-primary)]"></i>
          <span>สัญญา</span>
        </button>
        <!-- Invoice -->
        <button
          (click)="goToInvoices()"
          class="flex flex-col items-center justify-center gap-1 px-3 py-3 rounded-lg border border-[var(--border)] bg-[var(--sidebar)] hover:bg-[var(--sidebar-hover)] transition-all text-sm text-[var(--text)]"
        >
          <i class="bi bi-receipt text-xl text-[var(--crm-primary)]"></i>
          <span>Invoice</span>
        </button>
        <!-- MA Ticket -->
        <button
          (click)="goToMATickets()"
          class="flex flex-col items-center justify-center gap-1 px-3 py-3 rounded-lg border border-[var(--border)] bg-[var(--sidebar)] hover:bg-[var(--sidebar-hover)] transition-all text-sm text-[var(--text)]"
        >
          <i class="bi bi-headset text-xl text-[var(--crm-primary)]"></i>
          <span>MA Ticket</span>
        </button>
        <!-- Renewal -->
        <button
          (click)="goToRenewals()"
          class="flex flex-col items-center justify-center gap-1 px-3 py-3 rounded-lg border border-[var(--border)] bg-[var(--sidebar)] hover:bg-[var(--sidebar-hover)] transition-all text-sm text-[var(--text)]"
        >
          <i class="bi bi-arrow-repeat text-xl text-[var(--crm-primary)]"></i>
          <span>Renewal</span>
        </button>
        <!-- Approval -->
        <button
          (click)="goToApprovals()"
          class="flex flex-col items-center justify-center gap-1 px-3 py-3 rounded-lg border border-[var(--border)] bg-[var(--sidebar)] hover:bg-[var(--sidebar-hover)] transition-all text-sm text-[var(--text)]"
        >
          <i class="bi bi-check-circle text-xl text-[var(--crm-success)]"></i>
          <span>Approval</span>
        </button>
        <!-- Version Control -->
        <button
          (click)="goToVersions()"
          class="flex flex-col items-center justify-center gap-1 px-3 py-3 rounded-lg border border-[var(--border)] bg-[var(--sidebar)] hover:bg-[var(--sidebar-hover)] transition-all text-sm text-[var(--text)]"
        >
          <i class="bi bi-tags text-xl text-[var(--crm-primary)]"></i>
          <span>Version</span>
        </button>
        <!-- Gantt -->
        <button
          (click)="goToGantt()"
          class="flex flex-col items-center justify-center gap-1 px-3 py-3 rounded-lg border border-[var(--border)] bg-[var(--sidebar)] hover:bg-[var(--sidebar-hover)] transition-all text-sm text-[var(--text)]"
        >
          <i class="bi bi-bar-chart-fill text-xl text-[var(--crm-primary)]"></i>
          <span>Gantt</span>
        </button>
      </div>
    </div>

    <!-- ===== RECENT PHASES & TASKS ===== -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Recent Phases -->
      <div
        class="bg-[var(--sidebar)] rounded-xl border border-[var(--border)] shadow-sm overflow-hidden"
      >
        <div class="flex items-center justify-between px-5 py-3 border-b border-[var(--border)]">
          <h3 class="font-semibold text-[var(--text-active)] flex items-center gap-2">
            <i class="bi bi-layers text-[var(--crm-primary)]"></i>
            Phase ล่าสุด
          </h3>
          <button (click)="goToPhases()" class="text-xs text-[var(--crm-primary)] hover:underline">
            ดูทั้งหมด →
          </button>
        </div>
        <div class="divide-y divide-[var(--border)]">
          @for (phase of p.recentPhases; track phase.id) {
            <div
              class="flex items-center justify-between px-5 py-3 hover:bg-[var(--sidebar-hover)] cursor-pointer transition-colors"
              (click)="goToPhaseDetail(phase.id)"
            >
              <div class="min-w-0">
                <p class="text-sm font-medium text-[var(--text-active)] truncate">
                  {{ phase.phaseName }}
                </p>
                <p class="text-xs text-[var(--text-muted)]">
                  {{ phase.phaseCode }} · {{ formatDate(phase.endDate) }}
                </p>
              </div>
              <div class="flex items-center gap-3">
                <span
                  [class]="
                    getStatusClass(phase.status) +
                    ' inline-block px-2 py-0.5 rounded-full text-[0.6rem] font-medium'
                  "
                >
                  {{ getStatusText(phase.status) }}
                </span>
                <span class="text-xs font-mono text-[var(--text-muted)] min-w-[2.5rem] text-right">
                  {{ phase.progress }}%
                </span>
                <div class="w-12 h-1.5 bg-[var(--bg)] rounded-full overflow-hidden">
                  <div
                    class="h-full rounded-full transition-all"
                    [style.width.%]="phase.progress"
                    [class]="getProgressClass(phase.progress)"
                  ></div>
                </div>
              </div>
            </div>
          } @empty {
            <div class="px-5 py-6 text-center text-[var(--text-muted)] text-sm">ไม่มี Phase</div>
          }
        </div>
      </div>

      <!-- Recent Tasks -->
      <div
        class="bg-[var(--sidebar)] rounded-xl border border-[var(--border)] shadow-sm overflow-hidden"
      >
        <div class="flex items-center justify-between px-5 py-3 border-b border-[var(--border)]">
          <h3 class="font-semibold text-[var(--text-active)] flex items-center gap-2">
            <i class="bi bi-list-task text-[var(--crm-primary)]"></i>
            งานล่าสุด
          </h3>
          <button (click)="goToTasks()" class="text-xs text-[var(--crm-primary)] hover:underline">
            ดูทั้งหมด →
          </button>
        </div>
        <div class="divide-y divide-[var(--border)]">
          @for (task of p.recentTasks; track task.id) {
            <div
              class="flex items-center justify-between px-5 py-3 hover:bg-[var(--sidebar-hover)] cursor-pointer transition-colors"
              (click)="goToTaskDetail(task.id)"
            >
              <div class="min-w-0">
                <p class="text-sm font-medium text-[var(--text-active)] truncate">
                  {{ task.taskName }}
                </p>
                <p class="text-xs text-[var(--text-muted)]">
                  {{ task.taskCode }} · {{ task.assignedTo }}
                </p>
              </div>
              <div class="flex items-center gap-2">
                <span
                  [class]="
                    getPriorityClass(task.priority) +
                    ' inline-block px-2 py-0.5 rounded-full text-[0.6rem] font-medium'
                  "
                >
                  {{ getPriorityText(task.priority) }}
                </span>
                <span
                  [class]="
                    getStatusClass(task.status) +
                    ' inline-block px-2 py-0.5 rounded-full text-[0.6rem] font-medium'
                  "
                >
                  {{ getStatusText(task.status) }}
                </span>
              </div>
            </div>
          } @empty {
            <div class="px-5 py-6 text-center text-[var(--text-muted)] text-sm">ไม่มีงาน</div>
          }
        </div>
      </div>
    </div>
  </div>
}
