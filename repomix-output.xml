      <p class="text-sm text-[var(--text-muted)]">กำลังโหลดข้อมูล...</p>
    </div>
  }

  <!-- TABLE -->
  @if (!isLoading()) {
    <div class="overflow-x-auto rounded-xl border border-[var(--border)] bg-[var(--sidebar)] shadow-sm">
      <table class="w-full text-sm">
        <thead class="bg-[var(--bg)] border-b border-[var(--border)]">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider min-w-[150px]">
              รหัส Flow
            </th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider min-w-[180px]">
              ชื่อ Flow
            </th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider min-w-[130px]">
              ประเภทเอกสาร
            </th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider min-w-[100px]">
              โหมด
            </th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider min-w-[60px]">
              Steps
            </th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider min-w-[80px]">
