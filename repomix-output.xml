<!-- ===== LOADING ===== -->
@if (isLoading) {
  <div class="flex flex-col items-center justify-center py-16 gap-4">
    <div class="w-12 h-12 border-4 border-[var(--border)] border-t-[var(--crm-primary)] rounded-full animate-spin"></div>
    <p class="text-[var(--text-muted)]">กำลังโหลดข้อมูล Specification...</p>
  </div>
}

<!-- ===== FORM ===== -->
@if (!isLoading && form) {
  <form [formGroup]="form" (ngSubmit)="submit()">
    <div class="grid grid-cols-6 gap-4">

      <!-- HEADER -->
      <div class="col-span-6 text-center">
        <h2 class="text-4xl font-semibold text-[var(--text-active)]">
          {{ isEdit ? 'แก้ไขข้อมูล Specification' : 'เพิ่มข้อมูล Specification' }}
        </h2>
      </div>

      <!-- Spec Code -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3">
        <sic-input
          label="รหัส Specification"
          formControlName="specCode"
          [required]="true"
          placeholder="SPEC-001"
        ></sic-input>
        @if (form.get('specCode')?.touched && form.get('specCode')?.invalid) {
          <p class="text-xs text-[var(--crm-danger)] mt-1">กรุณาระบุรหัส Specification</p>
        }
      </div>

      <!-- Spec Type -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3">
        <sic-combobox
          label="ประเภท Specification"
          formControlName="specType"
          [apiUrl]="service.apiGetLovSpecType"
          [required]="true"
        ></sic-combobox>
