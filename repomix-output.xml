                    <span class="text-xs text-[var(--text-muted)]">{{ comment.createdAt }}</span>
                  </div>
                  <p class="text-sm text-[var(--text)] mt-0.5">{{ comment.text }}</p>
                </div>
              </div>
            }
          </div>
        </div>
      }

      <!-- Add Comment (เฉพาะโหมดแก้ไข) -->
      @if (isEdit) {
        <div class="col-span-6">
          <h4 class="text-sm font-medium text-[var(--text-active)] mb-2">➕ เพิ่มความเห็น</h4>
          <div class="grid grid-cols-6 gap-4">
            <div class="col-span-4">
              <sic-input-area
                label="ข้อความ"
                [rows]="2"
                placeholder="เพิ่มความคิดเห็น..."
              ></sic-input-area>
            </div>
            <div class="col-span-2">
              <!-- ✅ เปลี่ยนจาก sic-combobox เป็น select -->
              <label class="block text-sm font-medium text-[var(--text-active)] mb-1">ประเภท</label>
              <select
                class="w-full px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--crm-primary)]/20 focus:border-[var(--crm-primary)] appearance-none pr-8 transition-all"
              >
                @for (type of commentTypeOptions; track type) {
                  <option [value]="type">{{ type }}</option>
                }
              </select>
              <sic-button [fullWidth]="true" [type]="'button'" variant="primary" class="mt-3">
                <i class="bi bi-plus-lg"></i>
                เพิ่ม
              </sic-button>
            </div>
          </div>
        </div>
      }
      <!-- Active Status -->
      <div
        class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3"
      >
        <label class="flex items-center gap-2 cursor-pointer text-sm">
          <input
            type="checkbox"
            formControlName="isActive"
            class="w-4 h-4 text-[var(--crm-primary)] focus:ring-[var(--crm-primary)]/20 rounded"
          />
          <span class="text-[var(--text-active)]">เปิดใช้งาน Design Review</span>
        </label>
      </div>

      <!-- Buttons -->
      <div
        class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3 flex gap-6 mt-5"
      >
        <div class="flex-1">
          <sic-button [fullWidth]="true" [type]="'button'" variant="secondary" (click)="onBack()">
            <i class="bi bi-arrow-left"></i>
            ย้อนกลับ
          </sic-button>
        </div>
        <div class="flex-1">
          <sic-button [fullWidth]="true" [type]="'submit'" variant="primary">
            <i class="bi bi-floppy"></i>
            {{ isEdit ? 'บันทึก' : 'สร้าง' }}
          </sic-button>
        </div>
      </div>
    </div>
  </form>
}
