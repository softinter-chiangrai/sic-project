      <!-- ❌ ลบฟิลด์ลูกค้าและโครงการออกแล้ว -->

      <!-- ✅ เปลี่ยนเป็น sic-datepicker -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3 flex gap-6">
        <div class="flex-1">
          <sic-datepicker
            label="วันที่เริ่ม"
            formControlName="startDate"
            [required]="true"
            placeholder="เลือกวันที่เริ่ม"
            dateFormat="DD/MM/YYYY"
          ></sic-datepicker>
        </div>
        <div class="flex-1">
          <sic-datepicker
            label="วันที่สิ้นสุด"
            formControlName="endDate"
            [required]="true"
            placeholder="เลือกวันที่สิ้นสุด"
            dateFormat="DD/MM/YYYY"
          ></sic-datepicker>
        </div>
      </div>

      <!-- Contract Value -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3">
        <sic-input
          label="มูลค่าสัญญา (บาท)"
          type="text"
          formControlName="contractValue"
          [required]="true"
          placeholder="0.00"
          [errorMessages]="{
            required: 'กรุณาระบุมูลค่าสัญญา',
            min: 'มูลค่าต้องมากกว่า 0'
          }"
        ></sic-input>
      </div>

      <!-- Payment Terms -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3">
        <sic-input
          label="เงื่อนไขการชำระเงิน"
          formControlName="paymentTerms"
          placeholder="เช่น จ่ายตามงวด 3 งวด, จ่ายรายเดือน"
        ></sic-input>
      </div>

      <!-- Scope Summary -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3">
        <sic-input-area
          label="สรุปขอบเขตงาน"
          formControlName="scopeSummary"
          [rows]="3"
          placeholder="ระบุขอบเขตงานหลักของสัญญานี้"
        ></sic-input-area>
      </div>

      <!-- Sign Status -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3">
        <sic-combobox
          label="สถานะลงนาม"
          formControlName="signStatus"
          [apiUrl]="service.getLovSignStatus()"
          [required]="true"
          [errorMessages]="{ required: 'กรุณาเลือกสถานะลงนาม' }"
        ></sic-combobox>
      </div>

      <!-- Active Status -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3">
        <label class="flex items-center gap-2 cursor-pointer text-sm">
          <input
            type="checkbox"
            formControlName="isActive"
            class="w-4 h-4 text-[var(--crm-primary)] focus:ring-[var(--crm-primary)]/20 rounded"
          />
          <span class="text-[var(--text-active)]">เปิดใช้งานสัญญา</span>
        </label>
      </div>

      <!-- Buttons -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3 flex gap-6 mt-5">
        <div class="flex-1">
          <sic-button
            [fullWidth]="true"
            [type]="'button'"
            variant="secondary"
            (click)="onBack()"
          >
            <i class="bi bi-arrow-left"></i>
            ย้อนกลับ
          </sic-button>
        </div>
        <div class="flex-1">
          <sic-button
            [fullWidth]="true"
            [type]="'submit'"
            variant="primary"
            [disabled]="isSaving"
          >
            @if (isSaving) {
              <i class="bi bi-arrow-repeat animate-spin"></i>
            } @else {
              <i class="bi bi-floppy"></i>
            }
            {{ isSaving ? 'กำลังบันทึก...' : (isEdit ? 'บันทึก' : 'สร้าง') }}
          </sic-button>
        </div>
      </div>

    </div>
  </form>
}
</file>

<file path="sic-app/src/app/feature/pm/rt/pmrt04/pmrt04B/pmrt04B.component.html">
<!-- src/app/feature/pm/rt/pmrt04/pmrt04B/pmrt04B.component.html -->

@if (isLoading) {
  <div class="flex flex-col items-center justify-center py-16 gap-4">
    <div
      class="w-12 h-12 border-4 border-[var(--border)] border-t-[var(--crm-primary)] rounded-full animate-spin"
    ></div>
    <p class="text-[var(--text-muted)]">กำลังโหลดข้อมูลสัญญา...</p>
  </div>
}

@if (!isLoading && originalContract) {
  <div class="max-w-4xl mx-auto p-0.5">
    <div class="flex items-center gap-3 mb-6">
      <button
        (click)="onBack()"
        class="w-9 h-9 rounded-lg flex items-center justify-center text-[var(--text-muted)] hover:text-[var(--crm-primary)] hover:bg-[var(--crm-primary)]/10 transition-all"
        title="กลับ"
      >
        <i class="bi bi-arrow-left text-xl"></i>
      </button>
      <h1 class="text-2xl font-bold text-[var(--text-active)] flex items-center gap-2">
        <i class="bi bi-arrow-repeat text-[var(--crm-primary)]"></i>
        ต่อสัญญา
      </h1>
      <span
        class="inline-block px-3 py-1 rounded-lg text-sm font-mono font-semibold bg-[var(--crm-primary)]/10 text-[var(--crm-primary)]"
      >
        {{ originalContract.contractNo }}
      </span>
    </div>

    <form [formGroup]="form" (ngSubmit)="submit()">
      <div class="space-y-6">
        <!-- ข้อมูลสัญญาเดิม -->
        <div class="bg-[var(--sidebar)] rounded-xl border border-[var(--border)] p-5 shadow-sm">
          <div class="text-sm font-semibold text-[var(--text-active)] mb-3 flex items-center gap-2">
            <i class="bi bi-file-earmark-text text-[var(--crm-primary)]"></i>
            ข้อมูลสัญญาเดิม
          </div>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div>
              <p class="text-xs text-[var(--text-muted)] uppercase tracking-wider">เลขที่สัญญา</p>
              <p class="text-sm font-medium text-[var(--text-active)]">{{ originalContract.contractNo }}</p>
            </div>
            <div>
              <p class="text-xs text-[var(--text-muted)] uppercase tracking-wider">ประเภท</p>
              <p class="text-sm font-medium text-[var(--text-active)]">{{ originalContract.contractType }}</p>
            </div>
            <div>
              <p class="text-xs text-[var(--text-muted)] uppercase tracking-wider">ลูกค้า</p>
              <p class="text-sm font-medium text-[var(--text-active)]">{{ originalContract.customerId || '-' }}</p>
            </div>
            <div>
              <p class="text-xs text-[var(--text-muted)] uppercase tracking-wider">โครงการ</p>
              <p class="text-sm font-medium text-[var(--text-active)]">{{ originalContract.projectId || '-' }}</p>
            </div>
            <div>
              <p class="text-xs text-[var(--text-muted)] uppercase tracking-wider">วันที่เริ่ม</p>
              <p class="text-sm font-medium text-[var(--text-active)]">{{ formatDate(originalContract.startDate) }}</p>
            </div>
            <div>
              <p class="text-xs text-[var(--text-muted)] uppercase tracking-wider">วันที่สิ้นสุด</p>
              <p class="text-sm font-medium text-[var(--text-active)]">{{ formatDate(originalContract.endDate) }}</p>
            </div>
            <div>
              <p class="text-xs text-[var(--text-muted)] uppercase tracking-wider">มูลค่า</p>
              <p class="text-sm font-medium text-[var(--text-active)]">{{ formatCurrency(originalContract.contractValue) }}</p>
            </div>
            <div>
              <p class="text-xs text-[var(--text-muted)] uppercase tracking-wider">สถานะการต่อ</p>
              <p class="text-sm font-medium text-[var(--text-active)]">{{ originalContract.renewalStatus || 'ยังไม่ต่อ' }}</p>
            </div>
          </div>
        </div>

        <div class="border-t border-[var(--border)] my-4"></div>

        <!-- ข้อมูลสัญญาใหม่ -->
        <div class="bg-[var(--sidebar)] rounded-xl border border-[var(--border)] p-5 shadow-sm">
          <div class="text-sm font-semibold text-[var(--text-active)] mb-3 flex items-center gap-2">
            <i class="bi bi-pencil-square text-[var(--crm-primary)]"></i>
            ข้อมูลสัญญาใหม่
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <!-- วันที่เริ่มใหม่ -->
            <div>
              <sic-datepicker
                label="วันที่เริ่ม (ใหม่)"
                formControlName="newStartDate"
                [required]="true"
                placeholder="เลือกวันที่เริ่ม"
                dateFormat="DD/MM/YYYY"
              ></sic-datepicker>
              @if (form.get('newStartDate')?.touched && form.get('newStartDate')?.invalid) {
                <p class="text-xs text-[var(--crm-danger)] mt-1">กรุณาระบุวันที่เริ่ม</p>
              }
            </div>

            <!-- วันที่สิ้นสุดใหม่ -->
            <div>
              <sic-datepicker
                label="วันที่สิ้นสุด (ใหม่)"
                formControlName="newEndDate"
                [required]="true"
                placeholder="เลือกวันที่สิ้นสุด"
                dateFormat="DD/MM/YYYY"
              ></sic-datepicker>
              @if (form.get('newEndDate')?.touched && form.get('newEndDate')?.invalid) {
                <p class="text-xs text-[var(--crm-danger)] mt-1">กรุณาระบุวันที่สิ้นสุด</p>
              }
              @if (form.hasError('endDateInvalid')) {
                <p class="text-xs text-[var(--crm-danger)] mt-1">
                  วันที่สิ้นสุดต้องมากกว่าวันที่เริ่ม
                </p>
              }
            </div>

            <!-- มูลค่าใหม่ -->
            <div>
              <sic-input
                label="มูลค่าสัญญา (ใหม่)"
                type="text"
                formControlName="newContractValue"
                [required]="true"
                placeholder="0.00"
              ></sic-input>
              @if (form.get('newContractValue')?.touched && form.get('newContractValue')?.invalid) {
                <p class="text-xs text-[var(--crm-danger)] mt-1">กรุณาระบุมูลค่า</p>
              }
            </div>

            <!-- สถานะการต่อ -->
            <div>
              <label class="block text-sm font-medium text-[var(--text-active)] mb-1"
                >สถานะการต่อสัญญา</label
              >
              <select
                formControlName="renewalStatus"
                class="w-full px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--crm-primary)]/20"
              >
                <option value="ต่อแล้ว">ต่อแล้ว</option>
                <option value="รอต่อ">รอต่อ</option>
                <option value="ยังไม่ต่อ">ยังไม่ต่อ</option>
                <option value="ยกเลิก">ยกเลิก</option>
              </select>
            </div>
          </div>

          <!-- หมายเหตุ -->
          <div class="mt-4">
            <sic-input-area
              label="หมายเหตุการต่อสัญญา"
              formControlName="renewalRemark"
              [rows]="2"
              placeholder="ระบุเหตุผลหรือรายละเอียดเพิ่มเติม (ถ้ามี)"
            ></sic-input-area>
          </div>
        </div>

        <!-- Buttons -->
        <div class="flex gap-4 pt-2">
          <div class="flex-1">
            <sic-button [fullWidth]="true" [type]="'button'" variant="secondary" (click)="onBack()">
              <i class="bi bi-arrow-left"></i>
              ย้อนกลับ
            </sic-button>
          </div>
          <div class="flex-[2]">
            <sic-button
              [fullWidth]="true"
              [type]="'submit'"
              variant="primary"
              [disabled]="isSaving || form.invalid"
            >
              @if (isSaving) {
                <i class="bi bi-arrow-repeat animate-spin"></i>
                กำลังบันทึก...
              } @else {
                <i class="bi bi-check-lg"></i>
                ยืนยันการต่อสัญญา
              }
            </sic-button>
          </div>
        </div>
      </div>
    </form>
  </div>
}
</file>

