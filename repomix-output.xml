            @if (crumb.icon) {
            <i class="bi text-[0.95rem]" [class]="crumb.icon"></i>
            }
            <span>{{ crumb.label }}</span>
          </a>
          } @else {
          <span class="inline-flex items-center gap-2 px-1 py-0.5 font-semibold"
            [class.text-[var(--text-active)]]="crumb.isCurrent" [class.text-[var(--text-muted)]]="!crumb.isCurrent">
            @if (crumb.icon) {
            <i class="bi text-[0.95rem]" [class]="crumb.icon" [class.text-[var(--crm-primary)]]="$index === 0"></i>
            }
            <span>{{ crumb.label }}</span>
          </span>
          }
          }
        </nav>

        <div class="flex items-center gap-2 text-[var(--text-muted)]">
          @if (isBack) {
            <button type="button" tooltip="ย้อนกลับ" (click)="onActionClick('back')"
              class="flex h-9 w-9 items-center justify-center rounded-lg transition-colors hover:bg-black/10 dark:hover:bg-white/10 hover:text-[var(--text-active)] cursor-pointer"
