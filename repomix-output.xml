<file path="sic-app/src/app/core/component/sic-ganttchart/ganttchart.component.html">
<div class="space-y-5 p-0.5">

  <!-- ===== HEADER ===== -->
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <h1 class="text-2xl font-semibold text-[var(--text-active)] flex items-center gap-2">
        <i class="bi bi-bar-chart-fill text-[var(--crm-primary)]"></i>
        Gantt Chart — แผนภาพ Timeline
      </h1>
      <span class="text-sm text-[var(--text-muted)] bg-[var(--bg)] px-3 py-0.5 rounded-full border border-[var(--border)]">
        {{ totalItems() }} งาน
      </span>
    </div>
  </div>

  <!-- ===== FILTERS ===== -->
  <div class="flex flex-wrap gap-3 items-center">
    <!-- Search -->
    <div class="relative flex-1 min-w-[200px]">
      <i class="bi bi-search absolute left-3 top-1/2 -translate-y-1/2 text-[var(--text-muted)] text-sm"></i>
      <input
        type="text"
        class="w-full pl-9 pr-9 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--crm-primary)]/20 focus:border-[var(--crm-primary)] transition-all"
        placeholder="ค้นหางาน, โครงการ, ผู้รับผิดชอบ..."
        [value]="searchTerm()"
        (input)="onSearch($event)"
      />
      @if (searchTerm()) {
        <button
          (click)="clearSearch()"
          class="absolute right-3 top-1/2 -translate-y-1/2 text-[var(--text-muted)] hover:text-[var(--text-active)] transition-colors"
        >
          <i class="bi bi-x-lg text-xs"></i>
        </button>
      }
    </div>

    <!-- Filter: Status -->
    <select
      (change)="onStatusChange($event)"
      [value]="filterStatus()"
      class="px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--crm-primary)]/20 focus:border-[var(--crm-primary)] appearance-none pr-8 cursor-pointer transition-all"
    >
      <option value="all">📊 ทุกสถานะ</option>
      @for (status of statusOptions; track status) {
        <option [value]="status">{{ getStatusText(status) }}</option>
      }
    </select>
  </div>

  <!-- ===== LOADING ===== -->
  @if (isLoading) {
    <div class="flex flex-col items-center justify-center py-12 gap-3">
      <div class="w-10 h-10 border-4 border-[var(--border)] border-t-[var(--crm-primary)] rounded-full animate-spin"></div>
      <p class="text-sm text-[var(--text-muted)]">กำลังโหลดข้อมูล...</p>
    </div>
  }

  <!-- ===== GANTT CHART ===== -->
  @if (!isLoading && filteredTasks().length > 0) {
    <div class="overflow-x-auto rounded-xl border border-[var(--border)] bg-[var(--sidebar)] shadow-sm">
      <div class="min-w-[800px]">
        <!-- Header: Date Labels -->
        <div class="flex border-b border-[var(--border)] bg-[var(--bg)]">
          <div class="w-[200px] flex-shrink-0 px-4 py-2 text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">
            งาน
          </div>
          <div class="flex-1 relative px-4 py-2">
            <div class="flex text-xs text-[var(--text-muted)]">
              @for (day of days(); track day) {
                <span class="flex-1 text-center">{{ day }}</span>
              }
            </div>
          </div>
        </div>

        <!-- Rows -->
        @for (task of paginatedTasks(); track task.id) {
          <div class="flex border-b border-[var(--border)] hover:bg-[var(--sidebar-hover)] transition-colors">
            <!-- Task Info -->
            <div class="w-[200px] flex-shrink-0 px-4 py-3">
              <div class="flex flex-col">
                <span class="text-sm font-medium text-[var(--text-active)]">{{ task.taskCode }}</span>
                <span class="text-xs text-[var(--text)] truncate">{{ task.taskName }}</span>
                <span class="text-xs text-[var(--text-muted)]">{{ task.assignedTo }}</span>
              </div>
            </div>

            <!-- Gantt Bar -->
            <div class="flex-1 relative px-4 py-3">
              <div class="relative h-8 w-full bg-[var(--bg)] rounded overflow-hidden">
                <div
                  class="absolute top-1 h-6 rounded transition-all cursor-pointer hover:shadow-md"
                  [style.left.%]="getBarPosition(task).left"
                  [style.width.%]="getBarPosition(task).width"
                  [style.background]="getBarColor(task.status)"
                  [style.opacity]="task.status === 'Cancelled' ? 0.4 : 1"
                  title="{{ task.taskCode }}"
                >
                  <span class="absolute inset-0 flex items-center justify-center text-xs text-white font-medium truncate px-1">
                    {{ task.taskCode }}
                  </span>
                </div>

                <!-- Status Badge -->
                <div class="absolute right-1 top-1">
                  <span [class]="getStatusClass(task.status) + ' inline-block px-1.5 py-0.5 rounded text-[0.55rem] font-medium'">
                    {{ getStatusText(task.status) }}
                  </span>
                </div>
              </div>
            </div>
          </div>
        }
      </div>
    </div>

    <!-- ===== LEGEND ===== -->
    <div class="flex flex-wrap items-center gap-4 text-xs text-[var(--text-muted)]">
      <span class="font-medium text-[var(--text-active)]">📌 สถานะ:</span>
      <span class="flex items-center gap-1">
        <span class="w-3 h-3 rounded bg-[var(--crm-secondary)]"></span>
        รอเริ่ม
      </span>
      <span class="flex items-center gap-1">
        <span class="w-3 h-3 rounded bg-[var(--crm-primary)]"></span>
        กำลังทำ
      </span>
      <span class="flex items-center gap-1">
        <span class="w-3 h-3 rounded bg-[var(--crm-warning)]"></span>
        รอ Review/แก้ไข
      </span>
      <span class="flex items-center gap-1">
        <span class="w-3 h-3 rounded bg-[var(--crm-success)]"></span>
        เสร็จ
      </span>
      <span class="flex items-center gap-1">
        <span class="w-3 h-3 rounded bg-[var(--crm-danger)]"></span>
        ล่าช้า/ติดปัญหา
      </span>
    </div>

  } @else if (!isLoading && filteredTasks().length === 0) {
    <div class="text-center py-12 text-[var(--text-muted)]">
      <i class="bi bi-inbox text-5xl block mb-3 opacity-30"></i>
      <p>ไม่พบข้อมูลงาน</p>
      <p class="text-sm">ปรับคำค้นหาหรือเพิ่มงานใหม่</p>
    </div>
  }

  <!-- ===== PAGINATION ===== -->
  @if (totalItems() > 0) {
    <div class="flex flex-wrap items-center justify-between gap-3 pt-1">
      <div class="text-sm text-[var(--text-muted)]">
        แสดง
        <strong class="text-[var(--text-active)]">{{ (currentPage() - 1) * pageSize() + 1 }}</strong>
        -
        <strong class="text-[var(--text-active)]">{{ Math.min(currentPage() * pageSize(), totalItems()) }}</strong>
        จาก
        <strong class="text-[var(--text-active)]">{{ totalItems() }}</strong>
        รายการ
      </div>

      <div class="flex gap-1">
        <button
          (click)="onPageChange(currentPage() - 1)"
          [disabled]="!hasPrevious()"
          class="min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] disabled:opacity-30 disabled:cursor-not-allowed transition-all"
        >
          <i class="bi bi-chevron-left"></i>
        </button>

        @for (page of pageNumbers(); track page) {
          <button
            (click)="onPageChange(page)"
            [class]="page === currentPage()
              ? 'min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg bg-[var(--crm-primary)] text-white font-medium transition-all'
              : 'min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] transition-all'
            "
          >
            {{ page }}
          </button>
        }

        <button
          (click)="onPageChange(currentPage() + 1)"
          [disabled]="!hasNext()"
          class="min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] disabled:opacity-30 disabled:cursor-not-allowed transition-all"
        >
          <i class="bi bi-chevron-right"></i>
        </button>
      </div>
    </div>
  }

</div>
