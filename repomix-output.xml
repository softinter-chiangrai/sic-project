<div class="sic-stepper-container" [class.sic-stepper-container--vertical]="orientation === 'vertical'">
  <nav class="sic-stepper" [attr.data-orientation]="orientation" aria-label="Progress">
    @for (step of steps; track trackStep($index, step)) {
      <div class="sic-stepper__item">
        <button
          type="button"
          class="sic-stepper__trigger"
          [class.sic-stepper__trigger--completed]="isCompleted($index)"
          [class.sic-stepper__trigger--current]="isCurrent($index)"
          [class.sic-stepper__trigger--readonly]="disabled"
          [class.sic-stepper__trigger--disabled]="step.disabled"
          [attr.aria-current]="isCurrent($index) ? 'step' : null"
          [disabled]="disabled || step.disabled"
          (click)="selectStep($index)">
          <span
            class="sic-stepper__badge"
            [class.sic-stepper__badge--disabled]="isDisabled($index)"
            [class.sic-stepper__badge--completed]="isCompleted($index)"
            [class.sic-stepper__badge--current]="isCurrent($index)">
            @if (isDisabled($index)) {
              <i class="bi bi-dash-lg"></i>
            } @else if (isCompleted($index)) {
              <i class="bi bi-check-lg"></i>
            } @else {
              {{ $index + 1 }}
            }
          </span>

          <span class="sic-stepper__content">
            <span class="sic-stepper__title">{{ step.title }}</span>
            @if (showDescriptions && step.description) {
              <span class="sic-stepper__description">{{ step.description }}</span>
            }
          </span>
        </button>

        @if ($index < steps.length - 1) {
          <span
            class="sic-stepper__line"
            [class.sic-stepper__line--completed]="isCompleted($index)"></span>
        }
      </div>
    }
  </nav>

  @if (hasProjectedSteps) {
    <section class="sic-stepper__panel">
      <div class="sic-stepper__panel-body">
        <ng-container *ngTemplateOutlet="currentTemplate()"></ng-container>
      </div>

      @if (showNavigation) {
        <div class="sic-stepper__panel-actions">
          <div class="sic-stepper__panel-actions-start">
            <sic-button
              variant="secondary"
              [disabled]="!canGoPrevious()"
              (click)="previous()">
              <i class="bi bi-arrow-left"></i>
              <span>{{ previousText }}</span>
            </sic-button>
          </div>

          <div class="sic-stepper__panel-actions-end">
            @if (showSkip && canSkip()) {
              <sic-button
                variant="ghost"
                (click)="skip()">
                <span>{{ skipText }}</span>
                <i class="bi bi-skip-forward"></i>
              </sic-button>
            }

            <sic-button
              [variant]="isLastStep() ? 'success' : 'primary'"
              (click)="next()">
              <span>{{ isLastStep() ? finishText : nextText }}</span>
              <i class="bi" [class.bi-check-lg]="isLastStep()" [class.bi-arrow-right]="!isLastStep()"></i>
            </sic-button>
          </div>
        </div>
      }
    </section>
  }
</div>
