            [required]="true"
          ></sic-combobox>
        </div>
      </div>

      <!-- Due Date -->
      <div
        class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3"
      >
        <sic-input
          label="กำหนดส่ง"
          type="text"
          formControlName="dueDate"
          [required]="true"
          placeholder="DD/MM/YYYY"
        ></sic-input>
        @if (form.get('dueDate')?.touched && form.get('dueDate')?.invalid) {
          <p class="text-xs text-[var(--crm-danger)] mt-1">กรุณาระบุกำหนดส่ง</p>
        }
      </div>

      <!-- Comments (แสดงเฉพาะในโหมดแก้ไข) -->
      @if (isEdit && form.get('comments')?.value?.length > 0) {
        <div class="col-span-6">
          <h3 class="text-lg font-semibold text-[var(--text-active)] mb-2">💬 ความเห็น</h3>
          <div class="space-y-2">
            @for (comment of form.get('comments')?.value; track comment.id) {
              <div
                class="flex items-start gap-3 p-3 rounded-lg bg-[var(--bg)] border border-[var(--border)]"
              >
                <div
                  class="w-8 h-8 rounded-full bg-[var(--crm-primary)]/10 flex items-center justify-center flex-shrink-0"
                >
                  <span class="text-xs font-semibold text-[var(--crm-primary)]">
