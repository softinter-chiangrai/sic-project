                    label="Email"
                    type="email"
                    [formControl]="inputMail"
                    [errorMessages]="{
                        required: 'Email is required',
                        email: 'Email format is invalid'
                    }"></sic-input>
                    <sic-number 
                        label="Amount" 
                        [formControl]="amount"
                    ></sic-number>
                    <sic-combobox
                        label="Combobox"
                        [apiUrl]="apiCombobox"
                        [paging]="true"
                        [pageSize]="10"
                        [params]="{ isActive: true }"
                        valueField="id"
                        textField="messageEn"
                        [formControl]="comboId">
                    </sic-combobox>
                    <sic-datepicker
                        label="Select Date"
                        placeholder="Choose a date"
                        dateFormat="D MMMM YYYY"
                        [maxDate]="maxDate"
                        [clearable]="true"
                        [formControl]="date">
                    </sic-datepicker>
                    <sic-timepicker
                        label="Select Time"
                        placeholder="Choose a time"
                        [formControl]="time"
                        >
                    </sic-timepicker>
                    <sic-checkbox 
                        [formControl]="checkbox"
                        label="Remember me"
                        [checkedValue]="1"
                        [uncheckedValue]="0" >
                    </sic-checkbox>
                    <sic-colorpicker
                        label="Select Color"
                        placeholder="Choose a color"
                        [formControl]="color"
                    ></sic-colorpicker>
                    <sic-input-area
                        label="Description"
                        placeholder="Enter your description"
                        [rows]="4"
                        [formControl]="textarea"
                        [errorMessages]="{ required: 'Description is required', minlength: 'Must be at least 10 characters' }">
                    </sic-input-area>
                    <sic-radio
                        label="Confirm"
                        direction="vertical"
                        [apiUrl]="apiRadio"
                        [formControl]="answer">
                    </sic-radio>
                    <sic-upload
                        label="Attachments"
                        [multiple]="true"
                        [visibility]="1"
                        [formControl]="uploads"
                        [uploadGroupId]="uploadGroupId.value"
                        [helperText]="'Upload documents, images, and videos in the same field'"
                        [errorMessages]="{ required: 'Please upload at least one file' }">
                    </sic-upload>
                    <sic-gridpanel
                        [config]="gridConfig"
                        (rowsChange)="onGridRowsChange($event)"
                        (rowAction)="onGridAction($event)">
                        <ng-template sicGridPanelTemplate="statusPill" let-row>
                            <span class="feature-grid-status"
                                [class.feature-grid-status--active]="row.isActive"
                                [class.feature-grid-status--inactive]="!row.isActive">
                                {{ row.isActive ? 'Active' : 'Inactive' }}
                            </span>
                        </ng-template>
                    </sic-gridpanel>

