              <td class="px-4 py-3">
                <span class="text-[var(--text-active)]">{{ contract.contractType }}</span>
              </td>
              <td class="px-4 py-3">
                <span class="text-[var(--text-active)]">{{ contract.customerName }}</span>
              </td>
              <td class="px-4 py-3">
                <button
                  (click)="goToProject(contract.projectId)"
                  class="text-[var(--crm-primary)] hover:underline transition-colors"
                >
                  {{ contract.projectName }}
                </button>
              </td>
              <td class="px-4 py-3 font-mono text-[var(--text-active)]">
                {{ formatCurrency(contract.contractValue) }}
              </td>
              <td class="px-4 py-3 text-sm text-[var(--text-muted)] font-mono hidden md:table-cell">
                {{ formatDate(contract.startDate) }} - {{ formatDate(contract.endDate) }}
              </td>
              <td class="px-4 py-3">
                <span
                  [class]="
                    getStatusClass(contract.signStatus) +
                    ' inline-block px-2.5 py-0.5 rounded-full text-xs font-medium'
                  "
                >
                  {{ getStatusText(contract.signStatus) }}
                </span>
              </td>
              <td class="px-4 py-3">
                <div class="flex items-center justify-center gap-1.5 flex-wrap">
                  <!-- ปุ่มแก้ไข -->
                  <button
                    (click)="goToEdit(contract.id)"
                    class="w-8 h-8 rounded-lg flex items-center justify-center text-[var(--text-muted)] hover:text-amber-500 hover:bg-amber-50 dark:hover:bg-amber-500/10 transition-all"
                    title="แก้ไข"
                  >
                    <i class="bi bi-pencil"></i>
                  </button>

                  <!-- แทนที่ปุ่มต่อสัญญาเดิม (บรรทัดที่ ~140) -->
                  <button
                    (click)="goToRenew(contract.id)"
                    class="w-8 h-8 rounded-lg flex items-center justify-center text-[var(--text-muted)] hover:text-[var(--crm-primary)] hover:bg-[var(--crm-primary)]/10 transition-all"
                    title="ต่อสัญญา"
                  >
