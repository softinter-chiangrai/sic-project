        }
      </div>
      <div>
        <sic-timepicker
          label="เวลาเริ่ม"
          formControlName="startTime"
          placeholder="เลือกเวลา"
        ></sic-timepicker>
      </div>
    </div>

    <!-- End Date + Time -->
    <div class="grid grid-cols-2 gap-4">
      <div>
        <sic-datepicker
          label="วันที่สิ้นสุด"
          formControlName="endDate"
          [required]="true"
          placeholder="เลือกวันที่สิ้นสุด"
        ></sic-datepicker>
        @if (form.get('endDate')?.touched && form.get('endDate')?.invalid) {
          <p class="text-xs text-[var(--crm-danger)] mt-1">กรุณาระบุวันที่สิ้นสุด</p>
        }
      </div>
      <div>
        <sic-timepicker
          label="เวลาสิ้นสุด"
          formControlName="endTime"
          placeholder="เลือกเวลา"
        ></sic-timepicker>
      </div>
    </div>

    <!-- Estimate Manday & Priority -->
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-[var(--text)]">Manday โดยประมาณ <span class="text-red-500">*</span></label>
        <input type="number" formControlName="estimateManday" class="w-full px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] focus:ring-2 focus:ring-[var(--crm-primary)]/20 focus:border-[var(--crm-primary)] outline-none transition-all" />
        @if (form.get('estimateManday')?.touched && form.get('estimateManday')?.invalid) {
          <p class="text-xs text-[var(--crm-danger)] mt-1">กรุณาระบุ Manday (มากกว่า 0)</p>
        }
      </div>
      <div>
        <label class="block text-sm font-medium text-[var(--text)]">ความสำคัญ</label>
        <select formControlName="priority" class="w-full px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] focus:ring-2 focus:ring-[var(--crm-primary)]/20 appearance-none pr-8 cursor-pointer transition-all">
          <option value="Low">ต่ำ</option>
          <option value="Medium">ปานกลาง</option>
          <option value="High">สูง</option>
          <option value="Critical">วิกฤต</option>
        </select>
      </div>
    </div>

    <!-- Color Picker -->
    <div>
      <sic-colorpicker
        label="เลือกสี Task"
        formControlName="color"
        placeholder="#2ECC71"
      ></sic-colorpicker>
    </div>

    <!-- Buttons -->
    <div class="flex gap-3 pt-4 border-t border-[var(--border)]">
      <button type="submit" [disabled]="form.invalid" class="px-6 py-2 rounded-lg text-sm font-medium text-white bg-[var(--crm-primary)] hover:bg-[var(--crm-primary)]/80 disabled:opacity-50 transition-all">
        {{ isEdit ? 'บันทึก' : 'สร้าง' }}
      </button>
      <button type="button" (click)="cancel()" class="px-6 py-2 rounded-lg text-sm font-medium border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] transition-all">
        ยกเลิก
      </button>
    </div>

  </form>
</div>
