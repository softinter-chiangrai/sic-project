                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th
              (click)="onSortChange('taskName')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[150px]"
            >
              ชื่องาน
              @if (sortBy() === 'taskName') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider whitespace-nowrap min-w-[100px]"
            >
              Manday
            </th>
            <th
              (click)="onSortChange('status')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[110px]"
            >
              สถานะ
              @if (sortBy() === 'status') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th
              (click)="onSortChange('priority')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[80px]"
            >
              Priority
              @if (sortBy() === 'priority') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider whitespace-nowrap min-w-[80px]">
              อัปเดต
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-[var(--border)]">
          @for (task of paginatedTasks(); track task.id) {
            <tr class="hover:bg-[var(--sidebar-hover)] transition-colors">
              <td class="px-4 py-3">
                <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold font-mono tracking-wide text-[var(--crm-primary)] bg-[var(--crm-primary)]/10">
                  {{ task.taskCode }}
                </span>
              </td>
              <td class="px-4 py-3">
                <div>
                  <div class="font-medium text-[var(--text-active)]">{{ task.taskName }}</div>
                  <div class="text-xs text-[var(--text-muted)]">Spec: {{ task.relatedSpec }}</div>
                  @if (task.dependency) {
                    <div class="text-xs text-[var(--crm-warning)]">⬆️ ต้องรอ: {{ task.dependencyName }}</div>
                  }
                </div>
              </td>
              <td class="px-4 py-3">
                <div class="flex flex-col gap-0.5">
                  <div class="flex justify-between text-xs">
                    <span class="text-[var(--text-muted)]">แผน: {{ task.estimateManday }}</span>
                    <span class="text-[var(--text-active)]">จริง: {{ task.actualManday }}</span>
                  </div>
                  <div class="w-full h-1.5 bg-[var(--bg)] rounded-full overflow-hidden">
                    <div
                      class="h-full rounded-full transition-all"
                      [style.width.%]="task.actualManday > 0 ? Math.min((task.actualManday / task.estimateManday) * 100, 100) : 0"
                      [style.background]="task.status === 'Done' ? 'var(--crm-success)' : task.status === 'Delayed' || task.status === 'Blocked' ? 'var(--crm-danger)' : 'var(--crm-primary)'"
                    ></div>
                  </div>
                </div>
              </td>
              <td class="px-4 py-3">
                <div class="flex items-center gap-1.5">
                  <i class="bi text-sm" [class]="getStatusIcon(task.status)"></i>
                  <span [class]="getStatusClass(task.status) + ' inline-block px-2.5 py-0.5 rounded-full text-xs font-medium'">
                    {{ getStatusText(task.status) }}
                  </span>
                </div>
              </td>
              <td class="px-4 py-3">
                <span [class]="getPriorityClass(task.priority) + ' inline-block px-2.5 py-0.5 rounded-full text-xs font-medium'">
                  {{ task.priority }}
                </span>
              </td>
              <td class="px-4 py-3 text-center">
                <!-- ✅ ปุ่มอัปเดต -->
                <button
                  (click)="goToUpdate(task.id)"
                  class="w-8 h-8 rounded-lg flex items-center justify-center text-[var(--text-muted)] hover:text-[var(--crm-primary)] hover:bg-[var(--crm-primary)]/10 transition-all"
                  title="อัปเดตสถานะ"
                >
                  <i class="bi bi-pencil-square"></i>
                </button>
              </td>
            </tr>
          } @empty {
            <tr>
              <td colspan="6" class="px-4 py-12 text-center">
                <div class="flex flex-col items-center gap-3">
                  <i class="bi bi-inbox text-5xl text-[var(--text-muted)] opacity-30"></i>
                  <p class="text-lg font-medium text-[var(--text-active)]">ไม่พบงานที่ได้รับมอบหมาย</p>
                  <p class="text-sm text-[var(--text-muted)]">ขณะนี้ยังไม่มีงานที่ได้รับมอบหมาย</p>
                </div>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }

  <!-- ===== PAGINATION ===== -->
  @if (totalItems() > 0) {
    <div class="flex flex-wrap items-center justify-between gap-3 pt-1">
      <div class="text-sm text-[var(--text-muted)]">
        แสดง
        <strong class="text-[var(--text-active)]">{{ (currentPage() - 1) * pageSize() + 1 }}</strong>
        -
        <strong class="text-[var(--text-active)]">{{ Math.min(currentPage() * pageSize(), totalItems()) }}</strong>
        จาก
        <strong class="text-[var(--text-active)]">{{ totalItems() }}</strong>
        รายการ
      </div>

      <div class="flex gap-1">
        <button
          (click)="onPageChange(currentPage() - 1)"
          [disabled]="!hasPrevious()"
          class="min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] disabled:opacity-30 disabled:cursor-not-allowed transition-all"
        >
          <i class="bi bi-chevron-left"></i>
        </button>

        @for (page of pageNumbers(); track page) {
          <button
            (click)="onPageChange(page)"
            [class]="page === currentPage()
              ? 'min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg bg-[var(--crm-primary)] text-white font-medium transition-all'
              : 'min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] transition-all'
            "
          >
            {{ page }}
          </button>
        }

        <button
          (click)="onPageChange(currentPage() + 1)"
          [disabled]="!hasNext()"
          class="min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] disabled:opacity-30 disabled:cursor-not-allowed transition-all"
        >
          <i class="bi bi-chevron-right"></i>
        </button>
      </div>
    </div>
  }

</div>
</file>

