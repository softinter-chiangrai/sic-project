<sic-sidebar>
    <router-outlet></router-outlet>
    <sic-stepper
        [steps]="steps"
        [(activeStep)]="currentStep"
        (stepSkip)="onStepSkip()"
        (finish)="onStepperFinish()">
        <ng-template sicStep>
            @if (gridPanelComponent && gridPanelTemplateDirective) {
                <ng-container></ng-container>
            }

            <form [formGroup]="form" (ngSubmit)="onSubmit()">
                <div class="space-y-3">
