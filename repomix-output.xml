<file path="sic-app/src/app/feature/pm/rt/pmrt01/pmrt01.component.html">
<!-- src/app/feature/pm/rt/pmrt01/pmrt01.component.html -->

<div class="space-y-5 p-0.5">
  <!-- HEADER -->
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <h1 class="text-2xl font-semibold text-[var(--text-active)] flex items-center gap-2">
        <i class="bi bi-people-fill text-[var(--crm-primary)]"></i>
        รายการลูกค้า
      </h1>
      <span
        class="text-sm text-[var(--text-muted)] bg-[var(--bg)] px-3 py-0.5 rounded-full border border-[var(--border)]"
      >
        {{ totalItems() }} รายการ
      </span>
    </div>
    <button
      (click)="goToAdd()"
      class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium text-white bg-[var(--crm-primary)] hover:bg-[var(--crm-primary)]/80 transition-all hover:shadow-md"
    >
      <i class="bi bi-plus-lg"></i> เพิ่มลูกค้า
    </button>
  </div>

  <!-- FILTERS -->
  <div class="flex flex-wrap gap-3 items-center">
    <div class="relative flex-1 min-w-[200px]">
      <i
        class="bi bi-search absolute left-3 top-1/2 -translate-y-1/2 text-[var(--text-muted)] text-sm"
      ></i>
      <input
        type="text"
        class="w-full pl-9 pr-9 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--crm-primary)]/20 focus:border-[var(--crm-primary)] transition-all"
        placeholder="ค้นหาชื่อ, อีเมล, เบอร์โทร หรือรหัส..."
        [value]="searchTerm()"
        (input)="onSearch($event)"
      />
      @if (searchTerm()) {
        <button
          (click)="clearSearch()"
          class="absolute right-3 top-1/2 -translate-y-1/2 text-[var(--text-muted)] hover:text-[var(--text-active)] transition-colors"
        >
          <i class="bi bi-x-lg text-xs"></i>
        </button>
      }
    </div>

    <select
      (change)="onFilterChange($event)"
      [value]="filterStatus()"
      class="custom-select px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--crm-primary)]/20 focus:border-[var(--crm-primary)] appearance-none pr-8 cursor-pointer transition-all"
    >
      <option value="all">🌐 ทั้งหมด</option>
      <option value="active">✅ ใช้งาน</option>
      <option value="inactive">⛔ ไม่ใช้งาน</option>
    </select>
  </div>

  <!-- LOADING -->
  @if (isLoading()) {
    <div class="flex flex-col items-center justify-center py-12 gap-3">
      <div
        class="w-10 h-10 border-4 border-[var(--border)] border-t-[var(--crm-primary)] rounded-full animate-spin"
      ></div>
      <p class="text-sm text-[var(--text-muted)]">กำลังโหลดข้อมูล...</p>
    </div>
  }

  <!-- TABLE -->
  @if (!isLoading()) {
    <div
      class="overflow-x-auto rounded-xl border border-[var(--border)] bg-[var(--sidebar)] shadow-sm"
    >
      <table class="w-full text-sm">
        <thead class="bg-[var(--bg)] border-b border-[var(--border)]">
          <tr>
            <th
              (click)="onSortChange('customerCode')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[100px]"
            >
              รหัส
              @if (sortBy() === 'customerCode') {
                <i
                  class="bi text-xs ml-1 text-[var(--crm-primary)]"
                  [class.bi-chevron-up]="sortDir() === 'asc'"
                  [class.bi-chevron-down]="sortDir() === 'desc'"
                ></i>
              }
            </th>
            <th
              (click)="onSortChange('companyNameEn')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[220px]"
            >
              ชื่อบริษัท
              @if (sortBy() === 'companyNameEn') {
                <i
                  class="bi text-xs ml-1 text-[var(--crm-primary)]"
                  [class.bi-chevron-up]="sortDir() === 'asc'"
                  [class.bi-chevron-down]="sortDir() === 'desc'"
                ></i>
              }
            </th>
            <th
              (click)="onSortChange('email')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[200px]"
            >
              อีเมล
              @if (sortBy() === 'email') {
                <i
                  class="bi text-xs ml-1 text-[var(--crm-primary)]"
                  [class.bi-chevron-up]="sortDir() === 'asc'"
                  [class.bi-chevron-down]="sortDir() === 'desc'"
                ></i>
              }
            </th>
            <th
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider whitespace-nowrap min-w-[120px]"
            >
              เบอร์โทร
            </th>
            <th
              (click)="onSortChange('isActive')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[90px]"
            >
              สถานะ
              @if (sortBy() === 'isActive') {
                <i
                  class="bi text-xs ml-1 text-[var(--crm-primary)]"
                  [class.bi-chevron-up]="sortDir() === 'asc'"
                  [class.bi-chevron-down]="sortDir() === 'desc'"
                ></i>
              }
            </th>
            <th
              class="px-4 py-3 text-center text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider whitespace-nowrap min-w-[160px]"
            >
              จัดการ
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-[var(--border)]">
          @for (customer of paginatedCustomers(); track customer.id) {
            <tr class="hover:bg-[var(--sidebar-hover)] transition-colors">
              <!-- รหัส -->
              <td class="px-4 py-3">
                <span
                  class="inline-block px-2 py-0.5 rounded text-xs font-semibold font-mono tracking-wide text-[var(--crm-primary)] bg-[var(--crm-primary)]/10"
                >
                  {{ customer.customerCode }}
                </span>
              </td>

              <!-- ชื่อบริษัท -->
              <td class="px-4 py-3">
                <div class="flex items-center gap-3">
                  @if (customer.uploadGroupData && customer.uploadGroupData.length > 0) {
                    <img
                      [src]="getImageUrl(customer)"
                      alt="{{ customer.companyNameEn }}"
                      class="w-9 h-9 rounded-full object-cover border border-[var(--border)] flex-shrink-0"
                      (error)="onImageError($event)"
                    />
                  } @else {
                    <div
                      class="w-9 h-9 rounded-full flex items-center justify-center text-xs font-semibold text-white bg-[var(--crm-primary)] flex-shrink-0 uppercase"
                    >
                      {{ getInitials(customer.companyNameEn) }}
                    </div>
                  }
                  <div class="min-w-0">
                    <div class="font-medium text-[var(--text-active)] truncate">
                      {{ customer.companyNameEn }}
                    </div>
                    @if (customer.companyNameLocal) {
                      <div class="text-xs text-[var(--text-muted)] truncate">
                        {{ customer.companyNameLocal }}
                      </div>
                    }
                  </div>
                </div>
              </td>

              <!-- อีเมล -->
              <td class="px-4 py-3">
                <a
                  [href]="'mailto:' + customer.email"
                  class="text-[var(--crm-primary)] hover:underline transition-colors"
                >
                  {{ customer.email }}
                </a>
              </td>

              <!-- เบอร์โทร -->
              <td class="px-4 py-3 font-mono text-[var(--text-active)]">
                {{ customer.phoneNumber || '-' }}
              </td>

              <!-- สถานะ -->
              <td class="px-4 py-3">
                <span
                  [class]="
                    getStatusClass(customer.isActive) +
                    ' inline-block px-2.5 py-0.5 rounded-full text-xs font-medium'
                  "
                >
                  {{ getStatusText(customer.isActive) }}
                </span>
              </td>

              <!-- จัดการ -->
              <td class="px-4 py-3">
                <div class="flex items-center justify-center gap-1">
                  <button
                    (click)="goToProjects(customer)"
                    class="w-8 h-8 rounded-lg flex items-center justify-center text-[var(--text-muted)] hover:text-blue-500 hover:bg-blue-50 dark:hover:bg-blue-500/10 transition-all"
                    title="ดูโครงการทั้งหมดของลูกค้ารายนี้"
                  >
                    <i class="bi bi-briefcase"></i>
                  </button>
                  <button
                    (click)="goToEdit(customer.id)"
                    class="w-8 h-8 rounded-lg flex items-center justify-center text-[var(--text-muted)] hover:text-amber-500 hover:bg-amber-50 dark:hover:bg-amber-500/10 transition-all"
                    title="แก้ไข"
                  >
                    <i class="bi bi-pencil"></i>
                  </button>
                  <button
                    (click)="toggleActive(customer)"
                    class="w-8 h-8 rounded-lg flex items-center justify-center transition-all"
                    [class.text-emerald-500]="customer.isActive"
                    [class.text-gray-400]="!customer.isActive"
                    [class.hover:bg-emerald-50]="customer.isActive"
                    [class.hover:bg-gray-100]="!customer.isActive"
                    [class.dark:hover:bg-emerald-500/10]="customer.isActive"
                    [class.dark:hover:bg-gray-700]="!customer.isActive"
                    [title]="customer.isActive ? 'ปิดใช้งาน' : 'เปิดใช้งาน'"
                  >
                    <i
                      class="bi"
                      [class.bi-check-circle-fill]="customer.isActive"
                      [class.bi-x-circle]="!customer.isActive"
                    ></i>
                  </button>
                  <button
                    (click)="deleteCustomer(customer.id)"
                    class="w-8 h-8 rounded-lg flex items-center justify-center text-[var(--text-muted)] hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-500/10 transition-all"
                    title="ลบ"
                  >
                    <i class="bi bi-trash"></i>
                  </button>
                </div>
              </td>
            </tr>
          } @empty {
            <tr>
              <td colspan="6" class="px-4 py-12 text-center">
                <div class="flex flex-col items-center gap-3">
                  <i class="bi bi-inbox text-5xl text-[var(--text-muted)] opacity-30"></i>
                  <p class="text-lg font-medium text-[var(--text-active)]">ไม่พบข้อมูลลูกค้า</p>
                  <p class="text-sm text-[var(--text-muted)]">ปรับคำค้นหาหรือเพิ่มลูกค้าใหม่</p>
                  <button
                    [routerLink]="['/feature/pm/pmrt01/new']"
                    class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium text-white bg-[var(--crm-primary)] hover:bg-[var(--crm-primary)]/80 transition-all"
                  >
                    <i class="bi bi-plus-lg"></i> เพิ่มลูกค้า
                  </button>
                </div>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }

  <!-- PAGINATION -->
  @if (totalItems() > 0) {
    <div class="flex flex-wrap items-center justify-between gap-3 pt-1">
      <div class="text-sm text-[var(--text-muted)]">
        แสดง
        <strong class="text-[var(--text-active)]">{{
          (currentPage() - 1) * pageSize() + 1
        }}</strong>
        -
        <strong class="text-[var(--text-active)]">{{
          Math.min(currentPage() * pageSize(), totalItems())
        }}</strong>
        จาก
        <strong class="text-[var(--text-active)]">{{ totalItems() }}</strong>
        รายการ
      </div>

      <div class="flex gap-1">
        <button
          (click)="onPageChange(currentPage() - 1)"
          [disabled]="!hasPrevious()"
          class="min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] disabled:opacity-30 disabled:cursor-not-allowed transition-all"
        >
          <i class="bi bi-chevron-left"></i>
        </button>

        @for (page of pageNumbers(); track page) {
          <button
            (click)="onPageChange(page)"
            [class]="
              page === currentPage()
                ? 'min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg bg-[var(--crm-primary)] text-white font-medium transition-all'
                : 'min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] transition-all'
            "
          >
            {{ page }}
          </button>
        }

        <button
          (click)="onPageChange(currentPage() + 1)"
          [disabled]="!hasNext()"
          class="min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] disabled:opacity-30 disabled:cursor-not-allowed transition-all"
        >
          <i class="bi bi-chevron-right"></i>
        </button>
      </div>
    </div>
  }
</div>
