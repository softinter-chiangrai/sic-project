      />
    </div>
  </div>

  <div class="sic-profile-cropper-actions">
    <button
      type="button"
      class="sic-profile-cropper__secondary"
      [class.sic-profile-cropper__button--loading]="isSubmitting"
      (click)="cancelCrop()"
      [attr.aria-disabled]="isSubmitting"
