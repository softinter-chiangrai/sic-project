      </div>

      <!-- Status -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3">
        <sic-combobox
          label="สถานะ"
          formControlName="status"
          [apiUrl]="service.apiGetLovStatus"
          [required]="true"
        ></sic-combobox>
      </div>

      <!-- Changed By -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3">
        <sic-input
          label="ผู้เปลี่ยนแปลง"
          formControlName="changedBy"
          placeholder="สมหญิง รักเรียน"
        ></sic-input>
      </div>

      <!-- Changed Date -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3">
        <sic-input
          label="วันที่เปลี่ยนแปลง"
          type="text"
          formControlName="changedDate"
          [required]="true"
          placeholder="DD/MM/YYYY HH:MM"
        ></sic-input>
        @if (form.get('changedDate')?.touched && form.get('changedDate')?.invalid) {
          <p class="text-xs text-[var(--crm-danger)] mt-1">กรุณาระบุวันที่เปลี่ยนแปลง</p>
        }
      </div>

      <!-- Change Summary -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3">
        <sic-input-area
          label="สรุปการเปลี่ยนแปลง"
          formControlName="changeSummary"
          [required]="true"
          [rows]="3"
          placeholder="ระบุรายละเอียดการเปลี่ยนแปลงในเวอร์ชันนี้"
        ></sic-input-area>
        @if (form.get('changeSummary')?.touched && form.get('changeSummary')?.invalid) {
          <p class="text-xs text-[var(--crm-danger)] mt-1">กรุณาระบุสรุปการเปลี่ยนแปลง</p>
        }
      </div>

      <!-- Active Status -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3">
        <label class="flex items-center gap-2 cursor-pointer text-sm">
          <input
            type="checkbox"
            formControlName="isActive"
            class="w-4 h-4 text-[var(--crm-primary)] focus:ring-[var(--crm-primary)]/20 rounded"
          />
          <span class="text-[var(--text-active)]">เปิดใช้งานเวอร์ชันนี้</span>
        </label>
      </div>

      <!-- Buttons -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3 flex gap-6 mt-5">
        <div class="flex-1">
          <sic-button
            [fullWidth]="true"
            [type]="'button'"
            variant="secondary"
            (click)="onBack()"
          >
            <i class="bi bi-arrow-left"></i>
            ย้อนกลับ
          </sic-button>
        </div>
        <div class="flex-1">
          <sic-button
            [fullWidth]="true"
            [type]="'submit'"
            variant="primary"
          >
            <i class="bi bi-floppy"></i>
            {{ isEdit ? 'บันทึก' : 'สร้าง' }}
          </sic-button>
        </div>
      </div>

    </div>
  </form>
}
