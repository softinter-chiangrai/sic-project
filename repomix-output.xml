      </div>

      <!-- ✅ Status & Priority (ใช้ Select ธรรมดาแทน Combobox) -->
      <div class="col-span-11 col-start-1 md:col-span-4 md:col-start-2 lg:col-span-2 lg:col-start-3 flex gap-6">
        <div class="flex-1">
          <label class="block text-sm font-medium text-[var(--text-active)] mb-1">สถานะโครงการ</label>
          <select
            formControlName="status"
            class="w-full px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--crm-primary)]/20"
