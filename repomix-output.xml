    return of('บันทึกสำเร็จ').pipe(delay(500));
  }

  getTicket(id: string): Observable<MATicketModel> {
    const found = this.mockTickets.find((t) => t.id === id);
    if (found) {
      return of(found).pipe(delay(300));
    }
    const empty: MATicketModel = {
      id: '',
      ticketNo: '',
