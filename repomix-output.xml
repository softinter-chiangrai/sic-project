              } @else if (msg.messageType === 1) {
                <img [src]="msg.attachmentUrl ?? msg.message" class="headchat-msg-image" alt="รูปภาพ" loading="lazy" />
              } @else {
                <span class="headchat-msg-text">{{ msg.message }}</span>
              }
              <span class="headchat-msg-time">
                {{ msg.sentAt | date:'HH:mm' }}
              </span>
              @if (canCancel(msg)) {
                <button class="headchat-msg-cancel-btn" (click)="cancelMessage(msg)" title="ยกเลิกข้อความ">
                  <i class="bi bi-trash"></i>
