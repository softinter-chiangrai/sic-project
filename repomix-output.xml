        @if ((assigneeIds.value || []).length === 0) {
          <span class="text-sm text-[var(--text-muted)]">ยังไม่มีผู้รับผิดชอบร่วม</span>
        }
      </div>
    </div>

    <!-- Start Date + Time -->
    <div class="grid grid-cols-2 gap-4">
      <div>
        <sic-datepicker
