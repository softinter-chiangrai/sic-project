                  <p class="text-lg font-medium text-[var(--text-active)]">ไม่พบ Approval Flow</p>
                  <p class="text-sm text-[var(--text-muted)]">คลิก "สร้าง Approval Flow" เพื่อเริ่มต้น</p>
                  <button
                    (click)="openCreateForm()"
