  <div #surface class="sic-gridpanel__surface">
    <div class="sic-gridpanel__toolbar">
      <div class="sic-gridpanel__toolbar-start">
          <button type="button" class="sic-gridpanel__toolbar-button sic-gridpanel__toolbar-button--primary sic-gridpanel__toolbar-button--icon" [disabled]="!canSaveChanges" (click)="saveChanges()" aria-label="บันทึกข้อมูล" [tooltip]="saving ? 'กำลังบันทึก' : 'บันทึกข้อมูล'" tooltipPosition="bottom" [tooltipDisabled]="!canSaveChanges && !saving">
            <svg class="sic-gridpanel__toolbar-icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 4h11l3 3v13H5z"></path>
              <path d="M8 4v6h8"></path>
              <path d="M8 18v-5h8v5"></path>
            </svg>
          </button>
          <button type="button" class="sic-gridpanel__toolbar-button sic-gridpanel__toolbar-button--icon" [disabled]="isBusy" (click)="addRow()" aria-label="เพิ่มรายการ" [tooltip]="'เพิ่มรายการ'" tooltipPosition="bottom" [tooltipDisabled]="isBusy">
            <svg class="sic-gridpanel__toolbar-icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
