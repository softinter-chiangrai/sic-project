    const classes = [
      'sic-button',
      `sic-button--${this.variant}`,
      `sic-button--${this.size}`,
    ];

    if (this.fullWidth) {
      classes.push('sic-button--full-width');
    }

    if (this.iconOnly) {
      classes.push('sic-button--icon-only');
    }

    return classes.join(' ');
  }
}
