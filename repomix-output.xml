<!-- src/app/feature/pm/dt/pmdt03/pmdt03.component.html -->

<div class="space-y-5 p-0.5">

  <!-- ===== HEADER ===== -->
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <h1 class="text-2xl font-semibold text-[var(--text-active)] flex items-center gap-2">
        <i class="bi bi-check2-circle text-[var(--crm-primary)]"></i>
        ศูนย์อนุมัติ (Approval Center)
      </h1>
      <span class="text-sm text-[var(--text-muted)] bg-[var(--bg)] px-3 py-0.5 rounded-full border border-[var(--border)]">
        {{ totalItems() }} รายการ
      </span>
    </div>
    <div class="flex gap-2">
      <button
        (click)="onFilterChange($event)"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] transition-all"
      >
        <i class="bi bi-funnel"></i>
        กรอง
      </button>
    </div>
  </div>

  <!-- ===== TAB SWITCHER ===== -->
  <div class="flex gap-1 border-b border-[var(--border)]">
    <button
      (click)="viewMode.set('pending')"
      class="px-4 py-2 text-sm font-medium transition-colors border-b-2"
      [class]="viewMode() === 'pending' ? 'border-[var(--crm-primary)] text-[var(--crm-primary)]' : 'border-transparent text-[var(--text-muted)] hover:text-[var(--text-active)]'"
    >
      <i class="bi bi-clock-history mr-1"></i> รอฉันอนุมัติ
    </button>
    <button
      (click)="viewMode.set('myRequests')"
      class="px-4 py-2 text-sm font-medium transition-colors border-b-2"
      [class]="viewMode() === 'myRequests' ? 'border-[var(--crm-primary)] text-[var(--crm-primary)]' : 'border-transparent text-[var(--text-muted)] hover:text-[var(--text-active)]'"
    >
      <i class="bi bi-send mr-1"></i> คำขอของฉัน
    </button>
  </div>

  <!-- ===== FILTERS ===== -->
  <div class="flex flex-wrap gap-3 items-center">
    <!-- Search -->
    <div class="relative flex-1 min-w-[200px]">
      <i class="bi bi-search absolute left-3 top-1/2 -translate-y-1/2 text-[var(--text-muted)] text-sm"></i>
      <input
        type="text"
        class="w-full pl-9 pr-9 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--crm-primary)]/20 focus:border-[var(--crm-primary)] transition-all"
        placeholder="ค้นหารหัส, ชื่อ, ผู้ขอ..."
        [value]="searchTerm()"
        (input)="onSearch($event)"
      />
      @if (searchTerm()) {
        <button
          (click)="clearSearch()"
          class="absolute right-3 top-1/2 -translate-y-1/2 text-[var(--text-muted)] hover:text-[var(--text-active)] transition-colors"
        >
          <i class="bi bi-x-lg text-xs"></i>
        </button>
      }
    </div>

    <!-- Filter: Type -->
    <select
      (change)="onTypeChange($event)"
      [value]="filterType()"
      class="px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--crm-primary)]/20 focus:border-[var(--crm-primary)] appearance-none pr-8 cursor-pointer transition-all"
    >
      <option value="all">📋 ทุกประเภท</option>
      @for (type of documentTypes; track type) {
        <option [value]="type">{{ type }}</option>
