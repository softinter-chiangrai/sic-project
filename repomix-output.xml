                    <div class="headchat-msg-media-footer">
                      <span class="headchat-msg-file-name">{{ msg.attachmentFileName || 'วิดีโอบันทึก' }}</span>
                      <button class="headchat-msg-dl-btn" (click)="downloadFile(msg.attachmentUrl, msg.attachmentFileName)" title="ดาวน์โหลด">
                        <i class="bi bi-download"></i>
                      </button>
                    </div>
                  </div>
                } @else {
                  <div class="headchat-msg-file" (click)="downloadFile(msg.attachmentUrl, msg.attachmentFileName)" role="button" tabindex="0">
                    <i class="bi bi-file-earmark-fill"></i>
                    <div class="headchat-msg-file-info">
                      <span class="headchat-msg-file-name">{{ msg.attachmentFileName || 'ไฟล์แนบ' }}</span>
                      @if (msg.attachmentFileSize) {
                        <span class="headchat-msg-file-size">{{ formatFileSize(msg.attachmentFileSize) }}</span>
                      }
                    </div>
                    <i class="bi bi-download"></i>
                  </div>
                }
              } @else if (msg.messageType === 1) {
                <img [src]="msg.attachmentUrl ?? msg.message" class="headchat-msg-image" alt="รูปภาพ" loading="lazy" />
              } @else {
                <span class="headchat-msg-text">{{ msg.message }}</span>
              }
              <span class="headchat-msg-time">{{ msg.sentAt | date:'HH:mm' }}</span>
              @if (canCancelGroup(msg)) {
                <button class="headchat-msg-cancel-btn" (click)="cancelGroupMessage(msg)" title="ยกเลิกข้อความ">
                  <i class="bi bi-trash"></i>
                </button>
              }
            </div>
          }
        }
      </div>

      <!-- Input area -->
      <div class="headchat-input-row">
        <input type="file"
               accept="image/*,.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.csv,.rtf"
               #grpFileInput
               (change)="attachGroupFile(chat, $event)"
               hidden />
        <button class="headchat-input-btn" (click)="grpFileInput.click()" title="แนบไฟล์">
          <i class="bi bi-paperclip"></i>
        </button>
        <input
          class="headchat-input-text"
          type="text"
          placeholder="พิมพ์ข้อความ..."
          [(ngModel)]="chat.inputText"
          (keydown.enter)="onGroupEnter($event, chat)" />
        <button
          class="headchat-input-send"
          (click)="sendGroupMessage(chat)"
          [disabled]="!chat.inputText.trim()"
          title="ส่ง">
          <i class="bi bi-send-fill"></i>
        </button>
      </div>

    </div>
  }

  <!-- ── Edit group dialog ──────────────────────────────────────────────── -->
  @if (showEditGroup()) {
    <div class="headchat-overlay" (click)="closeEditGroupDialog()"></div>
    <div class="headchat-create-group-dialog">
      <div class="headchat-create-group-header">
        <span>แก้ไขกลุ่มสนทนา</span>
        <button class="headchat-panel-close" (click)="closeEditGroupDialog()">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>
      <div class="headchat-create-group-body">
        <label class="headchat-create-group-label">ชื่อกลุ่ม</label>
        <input class="headchat-create-group-input" type="text"
               placeholder="ระบุชื่อกลุ่ม"
               [(ngModel)]="editGroupName" />
        <label class="headchat-create-group-label">สมาชิก</label>
        <div class="headchat-create-group-members">
          @for (member of members(); track member.userId) {
            <label class="headchat-member-checkbox">
              <input type="checkbox"
                     [checked]="selectedEditMembers().has(member.userId)"
                     (change)="toggleEditMember(member.userId)" />
              <div class="headchat-member-avatar headchat-member-avatar--sm">
                @if (profileUrl(member.uploadGroupData)) {
                  <img [src]="profileUrl(member.uploadGroupData)" [alt]="member.displayName" />
