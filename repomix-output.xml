              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[130px]"
            >
              โครงการ
              @if (sortBy() === 'projectName') {
                <i
                  class="bi text-xs ml-1 text-[var(--crm-primary)]"
                  [class.bi-chevron-up]="sortDir() === 'asc'"
                  [class.bi-chevron-down]="sortDir() === 'desc'"
                ></i>
              }
            </th>
            <th
              (click)="onSortChange('contractValue')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[120px]"
            >
              มูลค่า
              @if (sortBy() === 'contractValue') {
                <i
                  class="bi text-xs ml-1 text-[var(--crm-primary)]"
                  [class.bi-chevron-up]="sortDir() === 'asc'"
                  [class.bi-chevron-down]="sortDir() === 'desc'"
                ></i>
              }
            </th>
            <th
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider whitespace-nowrap min-w-[140px] hidden md:table-cell"
            >
              ระยะเวลา
            </th>
            <th
              (click)="onSortChange('signStatus')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[100px]"
            >
              สถานะลงนาม
