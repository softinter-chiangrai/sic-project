              }
            </th>
            <th
              (click)="onSortChange('title')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[180px]"
            >
              รายการ
              @if (sortBy() === 'title') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th
              (click)="onSortChange('projectName')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[120px] hidden md:table-cell"
            >
              โครงการ
              @if (sortBy() === 'projectName') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th
              (click)="onSortChange('requester')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[100px] hidden lg:table-cell"
            >
              ผู้ขอ
              @if (sortBy() === 'requester') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th
              (click)="onSortChange('requestedDate')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[120px] hidden lg:table-cell"
            >
              วันที่ขอ
              @if (sortBy() === 'requestedDate') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th
              (click)="onSortChange('status')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[110px]"
            >
              สถานะ
              @if (sortBy() === 'status') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider whitespace-nowrap min-w-[120px]">
              ดำเนินการ
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-[var(--border)]">
          @for (item of paginatedApprovals(); track item.id) {
            <tr class="hover:bg-[var(--sidebar-hover)] transition-colors">
              <td class="px-4 py-3">
                <div class="flex items-center gap-2">
                  <i class="bi text-[var(--crm-primary)]" [class]="getDocumentIcon(item.documentType)"></i>
                  <div>
                    <div class="text-xs text-[var(--text-muted)]">{{ item.documentType }}</div>
                    <div class="text-sm font-mono font-semibold text-[var(--text-active)]">{{ item.documentCode }}</div>
                  </div>
                </div>
              </td>
              <td class="px-4 py-3">
                <div>
                  <div class="font-medium text-[var(--text-active)]">{{ item.title }}</div>
                  <div class="text-xs text-[var(--text-muted)]">ผู้อนุมัติ: {{ item.approver }}</div>
                </div>
              </td>
              <td class="px-4 py-3 hidden md:table-cell">
                <span class="text-[var(--text)]">{{ item.projectName }}</span>
              </td>
              <td class="px-4 py-3 hidden lg:table-cell">
                <span class="text-[var(--text-active)]">{{ item.requester }}</span>
              </td>
              <td class="px-4 py-3 hidden lg:table-cell">
                <span class="text-sm text-[var(--text-muted)]">{{ formatDate(item.requestedDate) }}</span>
              </td>
              <td class="px-4 py-3">
                <span [class]="getStatusClass(item.status) + ' inline-block px-2.5 py-0.5 rounded-full text-xs font-medium'">
                  {{ getStatusText(item.status) }}
                </span>
              </td>
              <td class="px-4 py-3 text-center">
                @if (item.status === 'PENDING') {
                  <button
                    (click)="goToApproval(item.id)"
                    class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-medium text-white bg-[var(--crm-primary)] hover:bg-[var(--crm-primary)]/80 transition-all"
                  >
                    <i class="bi bi-check2"></i>
                    อนุมัติ
                  </button>
                } @else {
                  <button
                    (click)="goToApproval(item.id)"
                    class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-medium border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] transition-all"
                  >
                    <i class="bi bi-eye"></i>
                    ดู
                  </button>
                }
              </td>
            </tr>
          } @empty {
            <tr>
              <td colspan="7" class="px-4 py-12 text-center">
                <div class="flex flex-col items-center gap-3">
                  <i class="bi bi-inbox text-5xl text-[var(--text-muted)] opacity-30"></i>
                  <p class="text-lg font-medium text-[var(--text-active)]">ไม่พบรายการอนุมัติ</p>
                  <p class="text-sm text-[var(--text-muted)]">ปรับคำค้นหาหรือรอรายการใหม่</p>
                </div>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }

  <!-- ===== PAGINATION ===== -->
  @if (totalItems() > 0) {
    <div class="flex flex-wrap items-center justify-between gap-3 pt-1">
      <div class="text-sm text-[var(--text-muted)]">
        แสดง
        <strong class="text-[var(--text-active)]">{{ (currentPage() - 1) * pageSize() + 1 }}</strong>
        -
        <strong class="text-[var(--text-active)]">{{ Math.min(currentPage() * pageSize(), totalItems()) }}</strong>
        จาก
        <strong class="text-[var(--text-active)]">{{ totalItems() }}</strong>
        รายการ
      </div>

      <div class="flex gap-1">
        <button
          (click)="onPageChange(currentPage() - 1)"
          [disabled]="!hasPrevious()"
          class="min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] disabled:opacity-30 disabled:cursor-not-allowed transition-all"
        >
          <i class="bi bi-chevron-left"></i>
        </button>

        @for (page of pageNumbers(); track page) {
          <button
            (click)="onPageChange(page)"
            [class]="page === currentPage()
              ? 'min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg bg-[var(--crm-primary)] text-white font-medium transition-all'
              : 'min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] transition-all'
            "
          >
            {{ page }}
          </button>
        }

        <button
          (click)="onPageChange(currentPage() + 1)"
          [disabled]="!hasNext()"
          class="min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] disabled:opacity-30 disabled:cursor-not-allowed transition-all"
        >
          <i class="bi bi-chevron-right"></i>
        </button>
      </div>
    </div>
  }

</div>
