<div class="space-y-5 p-0.5">
  <!-- HEADER -->
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <h1 class="text-2xl font-semibold text-[var(--text-active)] flex items-center gap-2">
        <i class="bi bi-clipboard-check text-[var(--crm-primary)]"></i>
        รายการ Requirement
      </h1>
      <span class="text-sm text-[var(--text-muted)] bg-[var(--bg)] px-3 py-0.5 rounded-full border border-[var(--border)]">
        {{ totalItems() }} รายการ
      </span>
    </div>
    <button
      (click)="goToAdd()"
      class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium text-white bg-[var(--crm-primary)] hover:bg-[var(--crm-primary)]/80 transition-all hover:shadow-md"
    >
      <i class="bi bi-plus-lg"></i> เพิ่ม Requirement
    </button>
  </div>

  <!-- FILTERS -->
  <div class="flex flex-wrap gap-3 items-center">
    <div class="relative flex-1 min-w-[200px]">
      <i class="bi bi-search absolute left-3 top-1/2 -translate-y-1/2 text-[var(--text-muted)] text-sm"></i>
      <input
        type="text"
        class="w-full pl-9 pr-9 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--crm-primary)]/20 focus:border-[var(--crm-primary)] transition-all"
        placeholder="ค้นหารหัส, ชื่อ..."
        [value]="searchTerm()"
        (input)="onSearch($event)"
      />
      @if (searchTerm()) {
        <button
          (click)="clearSearch()"
          class="absolute right-3 top-1/2 -translate-y-1/2 text-[var(--text-muted)] hover:text-[var(--text-active)] transition-colors"
        >
          <i class="bi bi-x-lg text-xs"></i>
        </button>
      }
    </div>
    <select
      (change)="onFilterChange($event)"
      [value]="filterStatus()"
      class="px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--crm-primary)]/20 focus:border-[var(--crm-primary)] appearance-none pr-8 cursor-pointer transition-all"
    >
      <option value="all">📊 ทุกสถานะ</option>
      <option value="Draft">ร่าง</option>
      <option value="In Review">อยู่ระหว่างตรวจสอบ</option>
      <option value="Approved">อนุมัติแล้ว</option>
      <option value="Changed">เปลี่ยนแปลง</option>
      <option value="Cancelled">ยกเลิก</option>
    </select>
  </div>

  <!-- LOADING -->
  @if (isLoading()) {
    <div class="flex flex-col items-center justify-center py-12 gap-3">
      <div class="w-10 h-10 border-4 border-[var(--border)] border-t-[var(--crm-primary)] rounded-full animate-spin"></div>
      <p class="text-sm text-[var(--text-muted)]">กำลังโหลดข้อมูล...</p>
    </div>
  }

  <!-- TABLE -->
  @if (!isLoading()) {
    <div class="overflow-x-auto rounded-xl border border-[var(--border)] bg-[var(--sidebar)] shadow-sm">
      <table class="w-full text-sm">
        <thead class="bg-[var(--bg)] border-b border-[var(--border)]">
          <tr>
            <th (click)="onSortChange('requirementCode')" class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[100px]">
              รหัส
              @if (sortBy() === 'requirementCode') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th (click)="onSortChange('title')" class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[150px]">
              ชื่อ
              @if (sortBy() === 'title') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th (click)="onSortChange('projectName')" class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[120px]">
              โครงการ
              @if (sortBy() === 'projectName') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th (click)="onSortChange('priority')" class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[80px]">
              Priority
              @if (sortBy() === 'priority') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th (click)="onSortChange('status')" class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[100px]">
              สถานะ
              @if (sortBy() === 'status') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider whitespace-nowrap min-w-[100px]">
              อนุมัติ
            </th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider whitespace-nowrap min-w-[100px] hidden md:table-cell">
              เวอร์ชัน
            </th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider whitespace-nowrap min-w-[180px]">
              จัดการ
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-[var(--border)]">
          @for (req of requirements(); track req.id) {
            <tr class="hover:bg-[var(--sidebar-hover)] transition-colors">
              <td class="px-4 py-3">
                <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold font-mono tracking-wide text-[var(--crm-primary)] bg-[var(--crm-primary)]/10">
                  {{ req.requirementCode }}
                </span>
              </td>
              <td class="px-4 py-3">
                <div>
                  <div class="font-medium text-[var(--text-active)]">{{ req.title }}</div>
                  <div class="text-xs text-[var(--text-muted)] truncate max-w-[200px]">{{ req.description }}</div>
                </div>
              </td>
              <td class="px-4 py-3">
                <span class="text-[var(--text)]">{{ req.projectName }}</span>
              </td>
              <td class="px-4 py-3">
                <span [class]="getPriorityClass(req.priority) + ' inline-block px-2.5 py-0.5 rounded-full text-xs font-medium'">
                  {{ req.priority }}
                </span>
              </td>
              <td class="px-4 py-3">
                <span [class]="getStatusClass(req.status) + ' inline-block px-2.5 py-0.5 rounded-full text-xs font-medium'">
                  {{ getStatusText(req.status) }}
                </span>
              </td>
              <td class="px-4 py-3">
                @if (req.approvalStatus) {
                  <span [class]="getApprovalStatusClass(req.approvalStatus) + ' inline-block px-2.5 py-0.5 rounded-full text-xs font-medium'">
                    {{ getApprovalStatusText(req.approvalStatus) }}
                  </span>
                } @else {
                  <span class="text-xs text-[var(--text-muted)]">-</span>
                }
              </td>
              <td class="px-4 py-3 text-[var(--text-muted)] font-mono text-sm hidden md:table-cell">
                {{ req.version }}
              </td>
              <td class="px-4 py-3 text-center">
                <div class="flex items-center justify-center gap-1">
                  <button (click)="goToView(req.id)" class="w-8 h-8 rounded-lg flex items-center justify-center text-[var(--text-muted)] hover:text-[var(--crm-primary)] hover:bg-[var(--crm-primary)]/10 transition-all" title="ดู">
                    <i class="bi bi-eye"></i>
                  </button>
                  @if (req.status === 'In Review' || req.status === 'Draft') {
                    <button (click)="goToApproval(req.id)" class="w-8 h-8 rounded-lg flex items-center justify-center text-[var(--text-muted)] hover:text-emerald-500 hover:bg-emerald-50 dark:hover:bg-emerald-500/10 transition-all" title="อนุมัติ">
                      <i class="bi bi-check2-circle"></i>
                    </button>
                  }
                  <button (click)="goToEdit(req.id)" class="w-8 h-8 rounded-lg flex items-center justify-center text-[var(--text-muted)] hover:text-amber-500 hover:bg-amber-50 dark:hover:bg-amber-500/10 transition-all" title="แก้ไข">
                    <i class="bi bi-pencil"></i>
                  </button>
                  <button (click)="deleteRequirement(req.id)" class="w-8 h-8 rounded-lg flex items-center justify-center text-[var(--text-muted)] hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-500/10 transition-all" title="ลบ">
                    <i class="bi bi-trash"></i>
                  </button>
                </div>
              </td>
            </tr>
          } @empty {
            <tr>
              <td colspan="8" class="px-4 py-12 text-center">
                <div class="flex flex-col items-center gap-3">
                  <i class="bi bi-inbox text-5xl text-[var(--text-muted)] opacity-30"></i>
                  <p class="text-lg font-medium text-[var(--text-active)]">ไม่พบข้อมูล Requirement</p>
                  <p class="text-sm text-[var(--text-muted)]">ปรับคำค้นหาหรือเพิ่ม Requirement ใหม่</p>
                  <button (click)="goToAdd()" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium text-white bg-[var(--crm-primary)] hover:bg-[var(--crm-primary)]/80 transition-all">
                    <i class="bi bi-plus-lg"></i> เพิ่ม Requirement
                  </button>
                </div>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }

  <!-- PAGINATION -->
  @if (totalItems() > 0) {
    <div class="flex flex-wrap items-center justify-between gap-3 pt-1">
      <div class="text-sm text-[var(--text-muted)]">
        แสดง <strong class="text-[var(--text-active)]">{{ (currentPage() - 1) * pageSize() + 1 }}</strong>
        - <strong class="text-[var(--text-active)]">{{ Math.min(currentPage() * pageSize(), totalItems()) }}</strong>
        จาก <strong class="text-[var(--text-active)]">{{ totalItems() }}</strong> รายการ
      </div>
      <div class="flex gap-1">
        <button (click)="onPageChange(currentPage() - 1)" [disabled]="!hasPrevious()" class="min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] disabled:opacity-30 disabled:cursor-not-allowed transition-all">
          <i class="bi bi-chevron-left"></i>
        </button>
        @for (page of pageNumbers(); track page) {
          <button (click)="onPageChange(page)" [class]="page === currentPage() ? 'min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg bg-[var(--crm-primary)] text-white font-medium transition-all' : 'min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] transition-all'">
            {{ page }}
          </button>
        }
        <button (click)="onPageChange(currentPage() + 1)" [disabled]="!hasNext()" class="min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] disabled:opacity-30 disabled:cursor-not-allowed transition-all">
          <i class="bi bi-chevron-right"></i>
        </button>
      </div>
    </div>
  }
</div>
</file>

