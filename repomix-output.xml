      <p class="text-sm text-[var(--text-muted)]">กำลังโหลดข้อมูล...</p>
    </div>
  }

  <!-- ===== TABLE ===== -->
  @if (!isLoading()) {
    <div class="overflow-x-auto rounded-xl border border-[var(--border)] bg-[var(--sidebar)] shadow-sm">
      <table class="w-full text-sm">
        <thead class="bg-[var(--bg)] border-b border-[var(--border)]">
          <tr>
            <th
              (click)="onSortChange('testCode')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[100px]"
            >
              รหัส
              @if (sortBy() === 'testCode') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th
              (click)="onSortChange('module')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[130px]"
            >
              Module / Scenario
              @if (sortBy() === 'module') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider whitespace-nowrap min-w-[150px]"
            >
              Test Case
            </th>
            <th
              (click)="onSortChange('testType')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[100px] hidden lg:table-cell"
            >
              ประเภท
              @if (sortBy() === 'testType') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th
              (click)="onSortChange('status')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[100px]"
            >
              สถานะ
              @if (sortBy() === 'status') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider whitespace-nowrap min-w-[80px]"
            >
              Tester
            </th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider whitespace-nowrap min-w-[200px]">
              จัดการ
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-[var(--border)]">
          @for (testCase of paginatedTestCases(); track testCase.id) {
            <tr class="hover:bg-[var(--sidebar-hover)] transition-colors">
              <td class="px-4 py-3">
                <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold font-mono tracking-wide text-[var(--crm-primary)] bg-[var(--crm-primary)]/10">
                  {{ testCase.testCode }}
                </span>
              </td>
              <td class="px-4 py-3">
                <div>
                  <div class="font-medium text-[var(--text-active)]">{{ testCase.module }}</div>
                  <div class="text-xs text-[var(--text-muted)]">{{ testCase.scenario }}</div>
                </div>
              </td>
              <td class="px-4 py-3">
                <div class="text-sm text-[var(--text)]">{{ testCase.testCase }}</div>
                <div class="text-xs text-[var(--text-muted)] mt-0.5">
                  <span class="font-medium">Steps:</span> {{ testCase.steps.join(' → ') }}
                </div>
                <div class="text-xs text-[var(--text-muted)]">
                  <span class="font-medium">Expected:</span> {{ testCase.expectedResult }}
                </div>
              </td>
              <td class="px-4 py-3 hidden lg:table-cell">
                <span class="text-xs text-[var(--text)]">{{ testCase.testType }}</span>
              </td>
              <td class="px-4 py-3">
                <div class="flex items-center gap-1.5">
                  <i class="bi text-sm" [class]="getStatusIcon(testCase.status)"></i>
                  <span [class]="getStatusClass(testCase.status) + ' inline-block px-2.5 py-0.5 rounded-full text-xs font-medium'">
                    {{ getStatusText(testCase.status) }}
                  </span>
                </div>
              </td>
              <td class="px-4 py-3">
                <span class="text-[var(--text-active)] text-sm">{{ testCase.tester }}</span>
              </td>
              <td class="px-4 py-3">
                <div class="flex items-center justify-center gap-1">
                  <!-- View -->
                  <button
                    (click)="goToView(testCase.id)"
                    class="w-8 h-8 rounded-lg flex items-center justify-center text-[var(--text-muted)] hover:text-[var(--crm-primary)] hover:bg-[var(--crm-primary)]/10 transition-all"
                    title="ดูข้อมูล"
                  >
                    <i class="bi bi-eye"></i>
                  </button>
                  <!-- Execute (เฉพาะ Pending หรือ Fail) -->
                  @if (testCase.status === 'Pending' || testCase.status === 'Fail') {
                    <button
                      (click)="goToExecute(testCase.id)"
                      class="w-8 h-8 rounded-lg flex items-center justify-center text-[var(--text-muted)] hover:text-emerald-500 hover:bg-emerald-50 dark:hover:bg-emerald-500/10 transition-all"
                      title="ทดสอบ"
                    >
                      <i class="bi bi-play-fill"></i>
                    </button>
                  }
                  <!-- Edit -->
                  <button
                    (click)="goToEdit(testCase.id)"
                    class="w-8 h-8 rounded-lg flex items-center justify-center text-[var(--text-muted)] hover:text-amber-500 hover:bg-amber-50 dark:hover:bg-amber-500/10 transition-all"
                    title="แก้ไข"
                  >
                    <i class="bi bi-pencil"></i>
                  </button>
                </div>
              </td>
            </tr>
          } @empty {
            <tr>
              <td colspan="7" class="px-4 py-12 text-center">
                <div class="flex flex-col items-center gap-3">
                  <i class="bi bi-inbox text-5xl text-[var(--text-muted)] opacity-30"></i>
                  <p class="text-lg font-medium text-[var(--text-active)]">ไม่พบข้อมูล Test Case</p>
                  <p class="text-sm text-[var(--text-muted)]">ปรับคำค้นหาหรือเพิ่ม Test Case ใหม่</p>
                  <button
                    (click)="goToAdd()"
                    class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium text-white bg-[var(--crm-primary)] hover:bg-[var(--crm-primary)]/80 transition-all"
                  >
                    <i class="bi bi-plus-lg"></i>
                    เพิ่ม Test Case
                  </button>
                </div>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }

  <!-- ===== PAGINATION ===== -->
  @if (totalItems() > 0) {
    <div class="flex flex-wrap items-center justify-between gap-3 pt-1">
      <div class="text-sm text-[var(--text-muted)]">
        แสดง
        <strong class="text-[var(--text-active)]">{{ (currentPage() - 1) * pageSize() + 1 }}</strong>
        -
        <strong class="text-[var(--text-active)]">{{ Math.min(currentPage() * pageSize(), totalItems()) }}</strong>
        จาก
        <strong class="text-[var(--text-active)]">{{ totalItems() }}</strong>
        รายการ
      </div>

      <div class="flex gap-1">
        <button
          (click)="onPageChange(currentPage() - 1)"
          [disabled]="!hasPrevious()"
          class="min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] disabled:opacity-30 disabled:cursor-not-allowed transition-all"
        >
          <i class="bi bi-chevron-left"></i>
        </button>

        @for (page of pageNumbers(); track page) {
          <button
            (click)="onPageChange(page)"
            [class]="page === currentPage()
              ? 'min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg bg-[var(--crm-primary)] text-white font-medium transition-all'
              : 'min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] transition-all'
            "
          >
            {{ page }}
          </button>
        }

        <button
          (click)="onPageChange(currentPage() + 1)"
          [disabled]="!hasNext()"
          class="min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] disabled:opacity-30 disabled:cursor-not-allowed transition-all"
        >
          <i class="bi bi-chevron-right"></i>
        </button>
      </div>
    </div>
  }

</div>
