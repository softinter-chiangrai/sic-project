                    <sic-organizational-chart
                            [root]="organizationData()"
                            (dataChanged)="onBusinessChartDataChanged($event)">
                    </sic-organizational-chart>

                    <sic-task
                        label="Task Calendar"
                        [config]="taskConfig"
                        (tasksChange)="onCalendarTasksChange($event)">
                    </sic-task>
                    <sic-button type="submit">Submit</sic-button>
                </div>
            </form>
        </ng-template>

        <ng-template sicStep>
