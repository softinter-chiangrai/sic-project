              <path d="M5 12h14"></path>
            </svg>
          </button>
          <button type="button" class="sic-gridpanel__toolbar-button sic-gridpanel__toolbar-button--danger sic-gridpanel__toolbar-button--icon" [disabled]="isBusy || !canDeleteSelected" (click)="deleteSelectedRows()" aria-label="ลบรายการที่เลือก" [tooltip]="'ลบรายการที่เลือก'" tooltipPosition="bottom" [tooltipDisabled]="isBusy || !canDeleteSelected">
            <svg class="sic-gridpanel__toolbar-icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 6h18"></path>
              <path d="M8 6V4h8v2"></path>
              <path d="M19 6l-1 14H6L5 6"></path>
              <path d="M10 11v6"></path>
              <path d="M14 11v6"></path>
            </svg>
          </button>
          <button type="button" class="sic-gridpanel__toolbar-button sic-gridpanel__toolbar-button--icon" [class.sic-gridpanel__toolbar-button--active]="reviewChangesOnly" [disabled]="isBusy || !canReviewChanges" (click)="toggleReviewChanges()" aria-label="Review changed rows" [tooltip]="reviewChangesOnly ? 'กลับไปแสดงข้อมูลทั้งหมด' : 'แสดงเฉพาะข้อมูลที่มีการลบ เพิ่ม หรือแก้ไข ' + changedRowsCount + ' รายการ'" tooltipPosition="bottom" [tooltipDisabled]="isBusy || !canReviewChanges">
            <svg class="sic-gridpanel__toolbar-icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 12c2.6-4.2 5.6-6.3 9-6.3s6.4 2.1 9 6.3c-2.6 4.2-5.6 6.3-9 6.3S5.6 16.2 3 12"></path>
              <circle cx="12" cy="12" r="2.8"></circle>
            </svg>
          </button>
      </div>
    </div>

    <div class="sic-gridpanel__table">
      <div class="sic-gridpanel__header" [style.gridTemplateColumns]="gridTemplateColumns">
        <div class="sic-gridpanel__header-cell sic-gridpanel__header-cell--selection">
          <sic-checkbox
            [label]="''"
            [formControl]="selectAllControl"></sic-checkbox>
        </div>
        @for (column of visibleColumns; track trackColumn($index, column)) {
          <div class="sic-gridpanel__header-cell">
            @if (getHeaderTemplate(column); as headerTemplate) {
              <ng-container
                [ngTemplateOutlet]="headerTemplate"
                [ngTemplateOutletContext]="{ $implicit: column, column: column, sortedAsc: isSortedAsc(column), sortedDesc: isSortedDesc(column) }"></ng-container>
            } @else {
              <button
                type="button"
                class="sic-gridpanel__sort"
                [class.sic-gridpanel__sort--enabled]="column.sortable !== false"
                [disabled]="column.sortable === false"
                (click)="sortBy(column)">
                <span>{{ column.label }}</span>
                @if (column.sortable !== false) {
                  <span class="sic-gridpanel__sort-icons">
                    <span [class.sic-gridpanel__sort-icon--active]="isSortedAsc(column)">▲</span>
                    <span [class.sic-gridpanel__sort-icon--active]="isSortedDesc(column)">▼</span>
                  </span>
                }
              </button>
            }
          </div>
        }
      </div>

      @if (loading && rows.length === 0) {
        <div class="sic-gridpanel__state">Loading...</div>
      } @else if (rows.length === 0) {
        <div class="sic-gridpanel__state sic-gridpanel__state--empty">
          <div class="sic-gridpanel__state-visual" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 7.5h18"></path>
              <path d="M7 4.5h10"></path>
              <path d="M5 7.5v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-10"></path>
              <path d="M9.5 11.5v4"></path>
              <path d="M14.5 11.5v4"></path>
            </svg>
          </div>
          <div class="sic-gridpanel__state-title">{{ reviewChangesOnly ? 'No changed data' : 'No data found' }}</div>
          <div class="sic-gridpanel__state-subtitle">{{ reviewChangesOnly ? 'Try turning off review mode to see all rows.' : 'Try adjusting your search or add a new row.' }}</div>
        </div>
      } @else {
        @for (row of rows; track trackRow($index, row)) {
          <div class="sic-gridpanel__row" [class.sic-gridpanel__row--new]="getRowState(row) === 'new'" [class.sic-gridpanel__row--updated]="getRowState(row) === 'updated'" [class.sic-gridpanel__row--deleted]="isRowDeleted(row)" [class.sic-gridpanel__row--disabled]="isRowDisabled(row)" [style.gridTemplateColumns]="gridTemplateColumns">
            <div class="sic-gridpanel__cell sic-gridpanel__cell--selection">
              @if (canResetRow(row)) {
                <button
                  type="button"
                  class="sic-gridpanel__reset-row-button"
                  (click)="resetRow(row)"
                  aria-label="รีเซ็ตข้อมูลกลับค่าเดิม">
                  <i class="bi bi-arrow-counterclockwise" aria-hidden="true"></i>
                </button>
              } @else {
                <sic-checkbox
                  [label]="''"
                  [formControl]="getSelectionControl(row)"></sic-checkbox>
              }
            </div>
            @for (column of visibleColumns; track trackColumn($index, column)) {
              <div class="sic-gridpanel__cell" [class.sic-gridpanel__cell--number]="column.type === 'number'" [class.sic-gridpanel__cell--checkbox]="column.type === 'checkbox'" [class.sic-gridpanel__cell--radio]="column.type === 'radio'" [class.sic-gridpanel__cell--upload]="column.type === 'upload'">
                @if (getCellTemplate(column); as cellTemplate) {
                  <ng-container
                    [ngTemplateOutlet]="cellTemplate"
                    [ngTemplateOutletContext]="{ $implicit: row, row: row, column: column, value: row[column.name], deleted: isRowDeleted(row), disabled: isRowDisabled(row) }"></ng-container>
                } @else {
                  @switch (column.type) {
                    @case ('area') {
                      @if (shouldRenderCellField(row, column)) {
                        <sic-input-area
                          [label]="''"
                          [rows]="column.rows ?? 4"
                          [placeholder]="column.placeholder || ''"
                          [hint]="column.hint"
                          [readonly]="isCellReadonly(row, column)"
                          [errorMessages]="column.errorMessages ?? {}"
                          [formControl]="getControl(row, column)"></sic-input-area>
                      } @else {
                        <div class="sic-gridpanel__display sic-gridpanel__display--area">{{ formatCellValue(row, column) }}</div>
                      }
                    }
                    @case ('number') {
                      @if (shouldRenderCellField(row, column)) {
                        <sic-number
                          [label]="''"
                          [placeholder]="column.placeholder || ''"
                          [hint]="column.hint"
                          [decimal]="column.decimal"
                          [readonly]="isCellReadonly(row, column)"
                          [errorMessages]="column.errorMessages ?? {}"
                          [formControl]="getControl(row, column)"></sic-number>
                      } @else {
                        <span class="sic-gridpanel__display sic-gridpanel__display--number">{{ formatCellValue(row, column) }}</span>
                      }
                    }
                    @case ('date') {
                      @if (shouldRenderCellField(row, column)) {
                        <sic-datepicker
                          [label]="''"
                          [placeholder]="column.placeholder || ''"
                          [hint]="column.hint"
                          [dateFormat]="column.dateFormat"
                          [clearable]="column.clearable ?? true"
                          [minDate]="column.minDate"
                          [maxDate]="column.maxDate"
                          [readonly]="isCellReadonly(row, column)"
                          [errorMessages]="column.errorMessages ?? {}"
                          [formControl]="getControl(row, column)"></sic-datepicker>
                      } @else {
                        <span class="sic-gridpanel__display sic-gridpanel__display--with-icon">
                          <span class="sic-gridpanel__display-icon" aria-hidden="true">
                            <i class="bi bi-calendar"></i>
                          </span>
                          <span class="sic-gridpanel__display-value">{{ formatCellValue(row, column) }}</span>
                        </span>
                      }
                    }
                    @case ('time') {
                      @if (shouldRenderCellField(row, column)) {
                        <sic-timepicker
                          [label]="''"
                          [placeholder]="column.placeholder || ''"
                          [hint]="column.hint"
                          [readonly]="isCellReadonly(row, column)"
                          [errorMessages]="column.errorMessages ?? {}"
                          [formControl]="getControl(row, column)"></sic-timepicker>
                      } @else {
                        <span class="sic-gridpanel__display sic-gridpanel__display--with-icon">
                          <span class="sic-gridpanel__display-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                              <circle cx="12" cy="12" r="10"></circle>
                              <polyline points="12 6 12 12 16 14"></polyline>
                            </svg>
                          </span>
                          <span class="sic-gridpanel__display-value">{{ formatCellValue(row, column) }}</span>
                        </span>
                      }
                    }
                    @case ('color') {
                      @if (shouldRenderCellField(row, column)) {
                        <sic-colorpicker
                          [label]="''"
                          [placeholder]="column.placeholder || ''"
                          [hint]="column.hint"
                          [readonly]="isCellReadonly(row, column)"
                          [errorMessages]="column.errorMessages ?? {}"
                          [formControl]="getControl(row, column)"></sic-colorpicker>
                      } @else {
                        <span class="sic-gridpanel__display">{{ formatCellValue(row, column) }}</span>
                      }
                    }
                    @case ('upload') {
                      @if (shouldRenderCellField(row, column)) {
                        <sic-input-upload
                          [label]="''"
                          [placeholder]="column.placeholder || ''"
                          [hint]="column.hint"
                          [multiple]="resolveUploadMultiple(row, column)"
                          [category]="resolveUploadCategory(row, column)"
                          [visibility]="resolveUploadVisibility(row, column)"
                          [uploadGroupId]="resolveUploadGroupId(row, column)"
                          [accept]="resolveUploadAccept(row, column)"
                          [businessId]="resolveUploadBusinessId(row, column)"
                          [emptyText]="resolveUploadEmptyText(row, column)"
                          [helperText]="resolveUploadHelperText(row, column)"
                          [errorMessages]="column.errorMessages ?? {}"
                          [readonly]="isCellReadonly(row, column)"
                          [formControl]="getControl(row, column)"></sic-input-upload>
                      } @else {
                        <span class="sic-gridpanel__display">{{ formatCellValue(row, column) }}</span>
                      }
                    }
                    @case ('combobox') {
                      @if (shouldRenderCellField(row, column)) {
                        <sic-combobox
                          [label]="''"
                          [apiUrl]="column.apiUrl || ''"
                          [params]="getColumnParams(column)"
                          [paging]="column.paging ?? true"
                          [pageSize]="column.pageSize ?? 10"
                          [placeholder]="column.placeholder || ''"
                          [hint]="column.hint"
                          [valueField]="column.valueField || 'value'"
                          [textField]="column.textField || 'text'"
                          [readonly]="isCellReadonly(row, column)"
                          [errorMessages]="column.errorMessages ?? {}"
                          [formControl]="getControl(row, column)"></sic-combobox>
                      } @else {
                        <span class="sic-gridpanel__display">{{ formatCellValue(row, column) }}</span>
                      }
                    }
                    @case ('checkbox') {
                      @if (shouldRenderCellField(row, column)) {
                        <sic-checkbox
                          [label]="''"
                          [hint]="column.hint"
                          [readonly]="isCellReadonly(row, column)"
                          [checkedValue]="column.checkedValue ?? true"
                          [uncheckedValue]="column.uncheckedValue ?? false"
                          [errorMessages]="column.errorMessages ?? {}"
                          [formControl]="getControl(row, column)"></sic-checkbox>
                      } @else {
                        <span class="sic-gridpanel__display sic-gridpanel__display--checkbox">{{ formatCellValue(row, column) }}</span>
                      }
                    }
                    @case ('radio') {
                      @if (shouldRenderCellField(row, column)) {
                        <sic-radio
                          [label]="''"
                          [options]="getRadioOptions(column)"
                          [apiUrl]="column.apiUrl || ''"
                          [params]="getColumnParams(column)"
                          [valueField]="column.valueField || 'value'"
                          [textField]="column.textField || 'text'"
                          [direction]="column.direction ?? 'vertical'"
                          [readonly]="isCellReadonly(row, column)"
                          [hint]="column.hint"
                          [errorMessages]="column.errorMessages ?? {}"
                          [formControl]="getControl(row, column)"></sic-radio>
                      } @else {
                        <span class="sic-gridpanel__display">{{ formatCellValue(row, column) }}</span>
                      }
                    }
                    @case ('button') {
                      <button type="button" class="sic-gridpanel__button" (click)="rowAction.emit({ action: column.name, row: row, column: column })">
                        {{ column.buttonText || column.label }}
                      </button>
                    }
                    @default {
                      @if (shouldRenderCellField(row, column)) {
                        <sic-input
                          [label]="''"
                          [type]="'text'"
                          [placeholder]="column.placeholder || ''"
                          [hint]="column.hint"
                          [readonly]="isCellReadonly(row, column)"
                          [errorMessages]="column.errorMessages ?? {}"
                          [formControl]="getControl(row, column)"></sic-input>
                      } @else {
                        <span class="sic-gridpanel__display">{{ formatCellValue(row, column) }}</span>
                      }
                    }
                  }
                }
              </div>
            }
          </div>
        }
      }

      @if (hasFooter) {
        <div class="sic-gridpanel__footer" [style.gridTemplateColumns]="gridTemplateColumns">
          <div class="sic-gridpanel__footer-cell sic-gridpanel__footer-cell--selection"></div>
          @for (column of visibleColumns; track trackColumn($index, column)) {
            <div class="sic-gridpanel__footer-cell">
              @if (getFooterTemplate(column); as footerTemplate) {
                <ng-container
                  [ngTemplateOutlet]="footerTemplate"
                  [ngTemplateOutletContext]="{ $implicit: rows, rows: rows, column: column, deletedCount: deletedCount }"></ng-container>
              } @else {
                <span>{{ column.footerText || '' }}</span>
              }
            </div>
          }
        </div>
      }
    </div>

    <div class="sic-gridpanel__footer-bar">
      <div class="sic-gridpanel__summary">
        <span>Total {{ totalElements }} rows</span>
      </div>

      @if (showPager) {
        <div class="sic-gridpanel__pager">
          <div class="sic-gridpanel__pager-group sic-gridpanel__pager-group--nav">
            <button type="button" class="sic-gridpanel__pager-button" [disabled]="currentPage <= 1 || loading" (click)="goToPage(1)">
              First
            </button>
            <button type="button" class="sic-gridpanel__pager-button" [disabled]="currentPage <= 1 || loading" (click)="goToPreviousPage()">
              Prev
            </button>

            <div class="sic-gridpanel__pager-pages" aria-label="Pagination pages">
              @for (item of pagerItems; track $index) {
                @if (item === 'start-ellipsis' || item === 'end-ellipsis') {
                  <span class="sic-gridpanel__pager-ellipsis">...</span>
                } @else {
                  <button
                    type="button"
                    class="sic-gridpanel__pager-page"
                    [class.sic-gridpanel__pager-page--active]="item === currentPage"
                    [disabled]="loading || item === currentPage"
                    (click)="goToPage(item)">
                    {{ item }}
                  </button>
                }
              }
            </div>

            <button type="button" class="sic-gridpanel__pager-button" [disabled]="currentPage >= totalPages || loading" (click)="goToNextPage()">
              Next
            </button>
            <button type="button" class="sic-gridpanel__pager-button" [disabled]="currentPage >= totalPages || loading" (click)="goToPage(totalPages)">
              Last
            </button>
          </div>
        </div>
      }
    </div>

    @if (isBusy) {
      <output class="sic-gridpanel__loading-overlay" aria-live="polite" aria-busy="true">
        <span class="sic-gridpanel__loading-spinner" aria-hidden="true"></span>
        <span class="sic-gridpanel__loading-text">{{ saving ? 'Saving data...' : 'Loading data...' }}</span>
      </output>
    }
  </div>
</div>
