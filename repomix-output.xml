    <button
      type="button"
      class="sic-profile-cropper__primary"
      [class.sic-profile-cropper__button--loading]="isSubmitting"
      (click)="doCrop()"
      [attr.aria-disabled]="isSubmitting"
    >
      <span *ngIf="!isSubmitting">Use this photo</span>
      <span *ngIf="isSubmitting" class="sic-profile-cropper__loading-inline">
