                ></i>
              }
            </th>
            <th
              (click)="onSortChange('contractType')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[140px]"
            >
              ประเภท
              @if (sortBy() === 'contractType') {
                <i
                  class="bi text-xs ml-1 text-[var(--crm-primary)]"
                  [class.bi-chevron-up]="sortDir() === 'asc'"
                  [class.bi-chevron-down]="sortDir() === 'desc'"
                ></i>
