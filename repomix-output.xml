import &#123; FormBuilder, FormGroup, Validators &#125; from '@angular/forms';
import &#123; ToForm &#125; from '../../../core/types/form.type';
import &#123; ExampleModel &#125; from './example.model';

export class ExampleForm &#123;
  static createForm(fb: FormBuilder): FormGroup&lt;ToForm&lt;ExampleModel&gt;&gt; &#123;
    return fb.group&lt;ToForm&lt;ExampleModel&gt;&gt;(&#123;
      id:        fb.control(null),
      code:      fb.control(null, [Validators.required, Validators.maxLength(50)]),
      nameEn:    fb.control(null, [Validators.required, Validators.maxLength(100)]),
      nameLocal: fb.control(null, [Validators.required, Validators.maxLength(100)]),
      isActive:  fb.control(null),
      state:     fb.control(null),
      rowVersion: fb.control(null),
    &#125;);
  &#125;
&#125;</code></pre>
