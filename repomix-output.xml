    >
      <option value="all">📋 ทุกประเภท</option>
      @for (type of typeOptions; track type) {
        <option [value]="type">{{ type }}</option>
      }
    </select>

    <!-- Filter: Severity -->
    <select
      (change)="onSeverityChange($event)"
      [value]="filterSeverity()"
      class="px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] text-[var(--text)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--crm-primary)]/20 focus:border-[var(--crm-primary)] appearance-none pr-8 cursor-pointer transition-all"
    >
      <option value="all">⚠️ ทุกระดับ</option>
      @for (severity of severityOptions; track severity) {
        <option [value]="severity">{{ severity }}</option>
      }
    </select>
  </div>

  <!-- ===== LOADING ===== -->
  @if (isLoading()) {
    <div class="flex flex-col items-center justify-center py-12 gap-3">
      <div class="w-10 h-10 border-4 border-[var(--border)] border-t-[var(--crm-primary)] rounded-full animate-spin"></div>
      <p class="text-sm text-[var(--text-muted)]">กำลังโหลดข้อมูล...</p>
    </div>
  }

  <!-- ===== TABLE ===== -->
  @if (!isLoading()) {
    <div class="overflow-x-auto rounded-xl border border-[var(--border)] bg-[var(--sidebar)] shadow-sm">
      <table class="w-full text-sm">
        <thead class="bg-[var(--bg)] border-b border-[var(--border)]">
          <tr>
            <th class="px-4 py-3 w-10"></th>
            <th
              (click)="onSortChange('reviewCode')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[100px]"
            >
              รหัส
              @if (sortBy() === 'reviewCode') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th
              (click)="onSortChange('title')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[150px]"
            >
              ชื่องาน
              @if (sortBy() === 'title') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th
              (click)="onSortChange('reviewableType')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[120px]"
            >
              ประเภท
              @if (sortBy() === 'reviewableType') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th
              (click)="onSortChange('reviewer')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[100px]"
            >
              ผู้ตรวจ
              @if (sortBy() === 'reviewer') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th
              (click)="onSortChange('status')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[100px]"
            >
              สถานะ
              @if (sortBy() === 'status') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th
              (click)="onSortChange('severity')"
              class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider cursor-pointer hover:text-[var(--text-active)] transition-colors whitespace-nowrap min-w-[80px]"
            >
              ระดับ
              @if (sortBy() === 'severity') {
                <i class="bi text-xs ml-1 text-[var(--crm-primary)]" [class.bi-chevron-up]="sortDir() === 'asc'" [class.bi-chevron-down]="sortDir() === 'desc'"></i>
              }
            </th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider whitespace-nowrap min-w-[160px]">
              จัดการ
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-[var(--border)]">
          @for (review of paginatedReviews(); track review.id) {
            <tr class="hover:bg-[var(--sidebar-hover)] transition-colors">
              <td class="px-4 py-3 text-center">
                @if (review.comments.length > 0) {
                  <button
                    (click)="toggleExpand(review.id)"
                    class="w-6 h-6 flex items-center justify-center rounded hover:bg-[var(--sidebar-hover)] transition-colors"
                  >
                    <i class="bi" [class.bi-chevron-right]="expandedReview() !== review.id" [class.bi-chevron-down]="expandedReview() === review.id"></i>
                  </button>
                }
              </td>
              <td class="px-4 py-3">
                <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold font-mono tracking-wide text-[var(--crm-primary)] bg-[var(--crm-primary)]/10">
                  {{ review.reviewCode }}
                </span>
              </td>
              <td class="px-4 py-3">
                <div>
                  <div class="font-medium text-[var(--text-active)]">{{ review.title }}</div>
                  <div class="text-xs text-[var(--text-muted)] truncate max-w-[200px]">{{ review.description }}</div>
                </div>
              </td>
              <td class="px-4 py-3">
                <span class="text-[var(--text)]">{{ review.reviewableType }}</span>
                <div class="text-xs text-[var(--text-muted)]">{{ review.reviewableName }}</div>
              </td>
              <td class="px-4 py-3">
                <span class="text-[var(--text-active)]">{{ review.reviewer }}</span>
                <div class="text-xs text-[var(--text-muted)]">→ {{ review.assignedTo }}</div>
              </td>
              <td class="px-4 py-3">
                <span [class]="getStatusClass(review.status) + ' inline-block px-2.5 py-0.5 rounded-full text-xs font-medium'">
                  {{ review.status }}
                </span>
              </td>
              <td class="px-4 py-3">
                <span [class]="getSeverityClass(review.severity) + ' inline-block px-2.5 py-0.5 rounded-full text-xs font-medium'">
                  {{ review.severity }}
                </span>
              </td>
              <td class="px-4 py-3">
                <div class="flex items-center justify-center gap-1">
                  <!-- View -->
                  <button
                    (click)="goToView(review.id)"
                    class="w-8 h-8 rounded-lg flex items-center justify-center text-[var(--text-muted)] hover:text-[var(--crm-primary)] hover:bg-[var(--crm-primary)]/10 transition-all"
                    title="ดูข้อมูล"
                  >
                    <i class="bi bi-eye"></i>
                  </button>
                  <!-- Edit -->
                  <button
                    (click)="goToEdit(review.id)"
                    class="w-8 h-8 rounded-lg flex items-center justify-center text-[var(--text-muted)] hover:text-amber-500 hover:bg-amber-50 dark:hover:bg-amber-500/10 transition-all"
                    title="แก้ไข"
                  >
                    <i class="bi bi-pencil"></i>
                  </button>
                </div>
              </td>
            </tr>
            @if (expandedReview() === review.id && review.comments.length > 0) {
              <tr class="bg-[var(--bg)]/50">
                <td colspan="8" class="px-4 py-3">
                  <div class="pl-8">
                    <div class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider mb-2">
                      💬 ความเห็น ({{ review.comments.length }})
                    </div>
                    <div class="space-y-2">
                      @for (comment of review.comments; track comment.id) {
                        <div class="flex items-start gap-3 p-2 rounded-lg bg-[var(--bg)] border border-[var(--border)]">
                          <div class="w-7 h-7 rounded-full bg-[var(--crm-primary)]/10 flex items-center justify-center flex-shrink-0">
                            <span class="text-xs font-semibold text-[var(--crm-primary)]">
                              {{ comment.author.charAt(0) }}
                            </span>
                          </div>
                          <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2 flex-wrap">
                              <span class="text-sm font-medium text-[var(--text-active)]">{{ comment.author }}</span>
                              <span [class]="getCommentTypeClass(comment.type) + ' inline-block px-2 py-0.5 rounded text-xs font-medium'">
                                {{ comment.type }}
                              </span>
                              <span class="text-xs text-[var(--text-muted)]">{{ formatDateTime(comment.createdAt) }}</span>
                            </div>
                            <p class="text-sm text-[var(--text)] mt-0.5">{{ comment.text }}</p>
                          </div>
                        </div>
                      }
                    </div>
                  </div>
                </td>
              </tr>
            }
          } @empty {
            <tr>
              <td colspan="8" class="px-4 py-12 text-center">
                <div class="flex flex-col items-center gap-3">
                  <i class="bi bi-inbox text-5xl text-[var(--text-muted)] opacity-30"></i>
                  <p class="text-lg font-medium text-[var(--text-active)]">ไม่พบข้อมูล Design Review</p>
                  <p class="text-sm text-[var(--text-muted)]">ปรับคำค้นหาหรือสร้าง Design Review ใหม่</p>
                  <button
                    (click)="goToAdd()"
                    class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium text-white bg-[var(--crm-primary)] hover:bg-[var(--crm-primary)]/80 transition-all"
                  >
                    <i class="bi bi-plus-lg"></i>
                    สร้าง Design Review
                  </button>
                </div>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }

  <!-- ===== PAGINATION ===== -->
  @if (totalItems() > 0) {
    <div class="flex flex-wrap items-center justify-between gap-3 pt-1">
      <div class="text-sm text-[var(--text-muted)]">
        แสดง
        <strong class="text-[var(--text-active)]">{{ (currentPage() - 1) * pageSize() + 1 }}</strong>
        -
        <strong class="text-[var(--text-active)]">{{ Math.min(currentPage() * pageSize(), totalItems()) }}</strong>
        จาก
        <strong class="text-[var(--text-active)]">{{ totalItems() }}</strong>
        รายการ
      </div>

      <div class="flex gap-1">
        <button
          (click)="onPageChange(currentPage() - 1)"
          [disabled]="!hasPrevious()"
          class="min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] disabled:opacity-30 disabled:cursor-not-allowed transition-all"
        >
          <i class="bi bi-chevron-left"></i>
        </button>

        @for (page of pageNumbers(); track page) {
          <button
            (click)="onPageChange(page)"
            [class]="page === currentPage()
              ? 'min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg bg-[var(--crm-primary)] text-white font-medium transition-all'
              : 'min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] transition-all'
            "
          >
            {{ page }}
          </button>
        }

        <button
          (click)="onPageChange(currentPage() + 1)"
          [disabled]="!hasNext()"
          class="min-w-[2.25rem] h-9 flex items-center justify-center rounded-lg border border-[var(--border)] bg-transparent text-[var(--text)] hover:bg-[var(--sidebar-hover)] hover:border-[var(--crm-primary)] disabled:opacity-30 disabled:cursor-not-allowed transition-all"
        >
          <i class="bi bi-chevron-right"></i>
        </button>
      </div>
    </div>
  }

</div>
</file>

