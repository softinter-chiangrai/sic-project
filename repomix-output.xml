    const customerId = this.filterCustomerId();
    if (customerId) {
      this.navigation.navigate(['/feature/pm/pmrt02/new'], { queryParams: { customerId } });
    } else {
      this.navigation.navigate(['/feature/pm/pmrt02/new']);
