                  <div class="headchat-msg-media-wrap">
                    <audio controls [src]="msg.attachmentUrl" class="headchat-msg-audio" preload="metadata"></audio>
                    <div class="headchat-msg-media-footer">
                      <span class="headchat-msg-file-name">{{ msg.attachmentFileName || 'เสียงบันทึก' }}</span>
                      <button class="headchat-msg-dl-btn" (click)="downloadFile(msg.attachmentUrl, msg.attachmentFileName)" title="ดาวน์โหลด">
                        <i class="bi bi-download"></i>
