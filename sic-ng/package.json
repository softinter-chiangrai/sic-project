{
  "name": "sic-ng",
  "version": "0.1.0",
  "description": "sic-ng Angular component library",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build sic-ng",
    "postbuild": "node scripts/copy-theme-assets.js",
    "prepare": "npm run build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "packageManager": "npm@11.16.0",
  "module": "./dist/sic-ng/fesm2022/sic-ng.mjs",
  "types": "./dist/sic-ng/types/sic-ng.d.ts",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/sic-ng/types/sic-ng.d.ts",
      "default": "./dist/sic-ng/fesm2022/sic-ng.mjs"
    },
    "./theme/*": "./dist/sic-ng/theme/*"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "peerDependencies": {
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.5",
    "@angular/cdk": "^22.0.3",
    "@angular/cli": "^22.0.5",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^22.0.0",
    "prettier": "^3.8.1",
    "rxjs": "~7.8.0",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
